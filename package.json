{
  "name": "tsumugu",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Open-source, language-agnostic graded-reader + LLM-wiki engine. Client-side, offline, no paid API in the core.",
  "license": "Apache-2.0",
  "scripts": {
    "typecheck": "tsc -b --pretty",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "pnpm -r --filter \"./packages/*\" build",
    "dev": "pnpm --filter @tsumugu/web dev",
    "gen": "tsx scripts/gen/cli.ts",
    "validate:phase0": "tsx scripts/validate-phase0.ts"
  },
  "devDependencies": {
    "@tsumugu/demo-pack": "workspace:*",
    "@tsumugu/engine": "workspace:*",
    "@types/node": "^22.10.0",
    "jieba-wasm": "^2.4.0",
    "opencc-js": "^1.3.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "packageManager": "pnpm@11.5.1"
}
