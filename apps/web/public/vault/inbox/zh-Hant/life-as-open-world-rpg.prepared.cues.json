{
  "schema": "tsumugu/transcript-cues@1",
  "lang": "zh-Hant",
  "source": "transcript:life-as-open-world-rpg.zh-Hant.vtt",
  "videoId": "p-iL1LoN2To",
  "cues": [
    {
      "text": "最近 我收到了一個",
      "start": "00:00:00.000",
      "end": "00:00:01.041"
    },
    {
      "text": "看起來很新奇的小玩意兒",
      "start": "00:00:01.041",
      "end": "00:00:03.000"
    },
    {
      "text": "其實",
      "start": "00:00:03.000",
      "end": "00:00:03.500"
    },
    {
      "text": "它是一款多模態 AI 穿戴裝置",
      "start": "00:00:03.500",
      "end": "00:00:05.916"
    },
    {
      "text": "Looki L1",
      "start": "00:00:05.916",
      "end": "00:00:07.000"
    },
    {
      "text": "簡單說 就是它可以幫我記錄",
      "start": "00:00:07.000",
      "end": "00:00:08.958"
    },
    {
      "text": "並且讓 AI 理解我的生活",
      "start": "00:00:08.958",
      "end": "00:00:10.958"
    },
    {
      "text": "Looki L1 有兩個主要模式",
      "start": "00:00:11.000",
      "end": "00:00:13.000"
    },
    {
      "text": "故事模式和 AI 模式",
      "start": "00:00:13.000",
      "end": "00:00:14.750"
    },
    {
      "text": "故事模式用起來很簡單",
      "start": "00:00:14.750",
      "end": "00:00:16.500"
    },
    {
      "text": "只要開啟",
      "start": "00:00:16.500",
      "end": "00:00:17.500"
    },
    {
      "text": "故事模式",
      "start": "00:00:17.666",
      "end": "00:00:18.541"
    },
    {
      "text": "它就會按照我設定好的頻率",
      "start": "00:00:18.541",
      "end": "00:00:20.500"
    },
    {
      "text": "進行記錄",
      "start": "00:00:20.500",
      "end": "00:00:21.208"
    },
    {
      "text": "可以這樣 戴在脖子上",
      "start": "00:00:21.208",
      "end": "00:00:22.666"
    },
    {
      "text": "記錄我的第一視角",
      "start": "00:00:22.666",
      "end": "00:00:24.000"
    },
    {
      "text": "也可以磁吸在充電座上",
      "start": "00:00:24.000",
      "end": "00:00:26.125"
    },
    {
      "text": "持續記錄我的狀態",
      "start": "00:00:26.125",
      "end": "00:00:27.625"
    },
    {
      "text": "在一天結束時",
      "start": "00:00:27.625",
      "end": "00:00:28.791"
    },
    {
      "text": "把記錄的素材上傳 分析",
      "start": "00:00:28.791",
      "end": "00:00:30.875"
    },
    {
      "text": "最終可以自動生成一個簡單的 vlog",
      "start": "00:00:30.875",
      "end": "00:00:33.458"
    },
    {
      "text": "和一個 AI 漫畫",
      "start": "00:00:33.458",
      "end": "00:00:34.833"
    },
    {
      "text": "它的 AI 模式",
      "start": "00:00:34.833",
      "end": "00:00:35.791"
    },
    {
      "text": "和你問我答的 AI 工具不同",
      "start": "00:00:35.791",
      "end": "00:00:37.625"
    },
    {
      "text": "可以自行識別我在什麼情境",
      "start": "00:00:37.625",
      "end": "00:00:39.458"
    },
    {
      "text": "做了些什麼",
      "start": "00:00:39.458",
      "end": "00:00:40.125"
    },
    {
      "text": "並及時給出些建議",
      "start": "00:00:40.125",
      "end": "00:00:41.958"
    },
    {
      "text": "我還可以通過自定義探索寫 Prompt",
      "start": "00:00:46.333",
      "end": "00:00:48.541"
    },
    {
      "text": "來讓它按照我指定的規則行動",
      "start": "00:00:48.541",
      "end": "00:00:51.041"
    },
    {
      "text": "專心寫稿",
      "start": "00:00:51.041",
      "end": "00:00:51.916"
    },
    {
      "text": "看到我拿起手機",
      "start": "00:00:51.916",
      "end": "00:00:53.583"
    },
    {
      "text": "就提醒我回歸專注",
      "start": "00:00:53.583",
      "end": "00:00:56.000"
    },
    {
      "text": "一段時間體驗下來",
      "start": "00:01:06.041",
      "end": "00:01:07.291"
    },
    {
      "text": "Looki L1給我的感覺很像是在",
      "start": "00:01:07.291",
      "end": "00:01:09.625"
    },
    {
      "text": "Vibe 記日記",
      "start": "00:01:09.625",
      "end": "00:01:10.666"
    },
    {
      "text": "不需要你自己記錄",
      "start": "00:01:10.666",
      "end": "00:01:11.958"
    },
    {
      "text": "它會作為一個合格的外掛大腦",
      "start": "00:01:11.958",
      "end": "00:01:14.166"
    },
    {
      "text": "觀察你 記錄你 提醒你",
      "start": "00:01:14.166",
      "end": "00:01:16.125"
    },
    {
      "text": "把你或精彩或平凡的日常",
      "start": "00:01:16.125",
      "end": "00:01:18.208"
    },
    {
      "text": "留在它的機身裡",
      "start": "00:01:18.208",
      "end": "00:01:19.500"
    },
    {
      "text": "等著你覆盤",
      "start": "00:01:19.500",
      "end": "00:01:20.500"
    },
    {
      "text": "但這種感受",
      "start": "00:01:20.500",
      "end": "00:01:21.208"
    },
    {
      "text": "其實和真實的記日記",
      "start": "00:01:21.208",
      "end": "00:01:22.625"
    },
    {
      "text": "還是挺不一樣的",
      "start": "00:01:22.625",
      "end": "00:01:23.916"
    },
    {
      "text": "我問了幾個喜歡記日記 做手帳的朋友",
      "start": "00:01:23.916",
      "end": "00:01:26.375"
    },
    {
      "text": "日記對他們而言",
      "start": "00:01:26.375",
      "end": "00:01:27.583"
    },
    {
      "text": "更像是一個過程",
      "start": "00:01:27.583",
      "end": "00:01:28.666"
    },
    {
      "text": "他們在這個過程中",
      "start": "00:01:28.666",
      "end": "00:01:30.000"
    },
    {
      "text": "把特殊的經歷提取出來",
      "start": "00:01:30.000",
      "end": "00:01:31.666"
    },
    {
      "text": "整理思緒 疏導情緒",
      "start": "00:01:31.666",
      "end": "00:01:33.500"
    },
    {
      "text": "獲得一個觀察自己成長的簡易存檔",
      "start": "00:01:33.500",
      "end": "00:01:36.375"
    },
    {
      "text": "記日記的話",
      "start": "00:01:36.375",
      "end": "00:01:37.375"
    },
    {
      "text": "我會回顧一下今天發生的事情",
      "start": "00:01:37.375",
      "end": "00:01:39.625"
    },
    {
      "text": "以及我當時的情緒",
      "start": "00:01:39.625",
      "end": "00:01:40.958"
    },
    {
      "text": "我覺得這個情緒的東西",
      "start": "00:01:40.958",
      "end": "00:01:42.541"
    },
    {
      "text": "我可能只是比如說",
      "start": "00:01:42.541",
      "end": "00:01:44.000"
    },
    {
      "text": "心裡突然冒出來的一個小的感受",
      "start": "00:01:44.000",
      "end": "00:01:47.375"
    },
    {
      "text": "或者是一種思緒",
      "start": "00:01:47.375",
      "end": "00:01:48.625"
    },
    {
      "text": "這個是很難從畫面的角度來記錄下來的",
      "start": "00:01:48.625",
      "end": "00:01:51.333"
    }
  ]
}
