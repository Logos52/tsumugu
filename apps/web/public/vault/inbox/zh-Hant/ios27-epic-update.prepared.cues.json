{
  "schema": "tsumugu/transcript-cues@1",
  "lang": "zh-Hant",
  "source": "transcript:ios27-epic-update.zh-Hant.vtt",
  "videoId": "E5ShFx9unEQ",
  "cues": [
    {
      "text": "Apple 剛剛結束了",
      "start": "00:00:00.083",
      "end": "00:00:01.250"
    },
    {
      "text": "一年一度的開發者大會",
      "start": "00:00:01.250",
      "end": "00:00:03.166"
    },
    {
      "text": "公佈了新版本的 iOS",
      "start": "00:00:03.166",
      "end": "00:00:04.583"
    },
    {
      "text": "iPad OS",
      "start": "00:00:04.583",
      "end": "00:00:05.500"
    },
    {
      "text": "Mac OS 系統",
      "start": "00:00:05.500",
      "end": "00:00:06.500"
    },
    {
      "text": "沒有視覺上的重大變化",
      "start": "00:00:06.500",
      "end": "00:00:08.708"
    },
    {
      "text": "但是今年是一次很特別的發佈會",
      "start": "00:00:08.708",
      "end": "00:00:11.083"
    },
    {
      "text": "因為",
      "start": "00:00:11.083",
      "end": "00:00:11.416"
    },
    {
      "text": "這是我們最後一次聽到 Tim Cook 的",
      "start": "00:00:11.416",
      "end": "00:00:13.541"
    },
    {
      "text": "Good morning",
      "start": "00:00:13.833",
      "end": "00:00:14.750"
    },
    {
      "text": "而且 Tim 也帶來了他的\"臨別大禮\"",
      "start": "00:00:16.333",
      "end": "00:00:19.166"
    },
    {
      "text": "全新的 Apple Intelligence 形態",
      "start": "00:00:19.166",
      "end": "00:00:21.416"
    },
    {
      "text": "它可能會徹底改變",
      "start": "00:00:22.583",
      "end": "00:00:23.916"
    },
    {
      "text": "我們以後和蘋果設備的交互方式",
      "start": "00:00:23.916",
      "end": "00:00:26.375"
    },
    {
      "text": "我怎麼有很強的既視感",
      "start": "00:00:27.166",
      "end": "00:00:29.041"
    },
    {
      "text": "今年發佈會和 2024 年",
      "start": "00:00:29.041",
      "end": "00:00:30.625"
    },
    {
      "text": "蘋果智能首次登場的發佈會相比",
      "start": "00:00:30.625",
      "end": "00:00:33.166"
    },
    {
      "text": "唯一的區別就是",
      "start": "00:00:33.166",
      "end": "00:00:34.250"
    },
    {
      "text": "當時公佈的那些功能",
      "start": "00:00:34.250",
      "end": "00:00:35.750"
    },
    {
      "text": "並沒有做出來",
      "start": "00:00:35.750",
      "end": "00:00:36.666"
    },
    {
      "text": "所以我們看到的都是 PPT 演示",
      "start": "00:00:36.666",
      "end": "00:00:38.750"
    },
    {
      "text": "而今年重新發佈的 Siri AI",
      "start": "00:00:38.750",
      "end": "00:00:41.166"
    },
    {
      "text": "都是直接在設備上現場演示的",
      "start": "00:00:41.166",
      "end": "00:00:43.500"
    },
    {
      "text": "為了凸顯真實性",
      "start": "00:00:43.500",
      "end": "00:00:44.791"
    },
    {
      "text": "還放了很多非常逼真的",
      "start": "00:00:44.791",
      "end": "00:00:47.208"
    },
    {
      "text": "意思是 Siri AI 智能助理",
      "start": "00:00:52.250",
      "end": "00:00:54.416"
    },
    {
      "text": "這次真的",
      "start": "00:00:54.416",
      "end": "00:00:55.250"
    },
    {
      "text": "真的",
      "start": "00:00:55.250",
      "end": "00:00:55.750"
    },
    {
      "text": "要來了",
      "start": "00:00:56.416",
      "end": "00:00:57.208"
    },
    {
      "text": "但是但是",
      "start": "00:00:57.208",
      "end": "00:00:58.083"
    },
    {
      "text": "和 2024 年一樣",
      "start": "00:00:58.083",
      "end": "00:00:59.625"
    },
    {
      "text": "新的 Siri AI 還是和中國大陸用戶",
      "start": "00:00:59.625",
      "end": "00:01:03.208"
    },
    {
      "text": "沒有任何關係",
      "start": "00:01:03.208",
      "end": "00:01:04.625"
    },
    {
      "text": "所以我熬夜看完了",
      "start": "00:01:04.625",
      "end": "00:01:05.875"
    },
    {
      "text": "整個將近一個半小時的發佈會",
      "start": "00:01:05.875",
      "end": "00:01:07.958"
    },
    {
      "text": "也挺後悔的",
      "start": "00:01:08.083",
      "end": "00:01:09.166"
    },
    {
      "text": "我也並不知道還有什麼理由",
      "start": "00:01:09.166",
      "end": "00:01:10.541"
    },
    {
      "text": "說服各位繼續往下看",
      "start": "00:01:10.541",
      "end": "00:01:12.041"
    },
    {
      "text": "但為了能瞭解到",
      "start": "00:01:12.041",
      "end": "00:01:13.375"
    },
    {
      "text": "跑不了的在中國上線的",
      "start": "00:01:15.500",
      "end": "00:01:17.166"
    },
    {
      "text": "中國版",
      "start": "00:01:17.166",
      "end": "00:01:17.958"
    },
    {
      "text": "我們可以先看看",
      "start": "00:01:18.708",
      "end": "00:01:19.916"
    },
    {
      "text": "蘋果到底攢了什麼新功能",
      "start": "00:01:19.916",
      "end": "00:01:22.208"
    },
    {
      "text": "這就是關於 iOS 27",
      "start": "00:01:22.208",
      "end": "00:01:24.125"
    },
    {
      "text": "你所需要知道的一切",
      "start": "00:01:24.125",
      "end": "00:01:25.666"
    },
    {
      "text": "因為今年屬於修修補補的一年",
      "start": "00:01:27.500",
      "end": "00:01:29.291"
    },
    {
      "text": "iOS 26 引入了這麼多變化",
      "start": "00:01:29.291",
      "end": "00:01:31.458"
    },
    {
      "text": "bug 還沒修完呢",
      "start": "00:01:31.458",
      "end": "00:01:32.541"
    },
    {
      "text": "今年主要就是抓 bug",
      "start": "00:01:32.541",
      "end": "00:01:34.125"
    },
    {
      "text": "優化易用性 性能和穩定性",
      "start": "00:01:34.125",
      "end": "00:01:36.458"
    },
    {
      "text": "首先",
      "start": "00:01:36.458",
      "end": "00:01:37.125"
    },
    {
      "text": "雖然暫時沒有 Apple Intelligence",
      "start": "00:01:37.125",
      "end": "00:01:39.166"
    },
    {
      "text": "但是作為補償 給了",
      "start": "00:01:39.166",
      "end": "00:01:40.833"
    },
    {
      "text": "現在",
      "start": "00:01:42.166",
      "end": "00:01:42.625"
    },
    {
      "text": "鬧鐘在調休日也可以正常響起來了",
      "start": "00:01:42.625",
      "end": "00:01:45.708"
    },
    {
      "text": "然後 是解決了液態玻璃",
      "start": "00:01:45.708",
      "end": "00:01:47.625"
    },
    {
      "text": "眾口難調的問題",
      "start": "00:01:47.625",
      "end": "00:01:49.000"
    },
    {
      "text": "有的人覺得 玻璃很透很漂亮",
      "start": "00:01:49.000",
      "end": "00:01:51.416"
    },
    {
      "text": "但是有很多人覺得",
      "start": "00:01:51.416",
      "end": "00:01:52.666"
    },
    {
      "text": "太透了 影響可讀性",
      "start": "00:01:52.666",
      "end": "00:01:54.541"
    },
    {
      "text": "iOS 27 引入了一個",
      "start": "00:01:54.541",
      "end": "00:01:55.833"
    },
    {
      "text": "液態玻璃透明度的滑條",
      "start": "00:01:55.833",
      "end": "00:01:57.750"
    },
    {
      "text": "可以看自己的心情隨便滑",
      "start": "00:01:57.750",
      "end": "00:01:59.708"
    },
    {
      "text": "並且為了 Mac OS 上的 icon 可讀性",
      "start": "00:01:59.708",
      "end": "00:02:01.791"
    },
    {
      "text": "把工具欄背景加了回來",
      "start": "00:02:01.791",
      "end": "00:02:03.500"
    },
    {
      "text": "迷途知返",
      "start": "00:02:03.583",
      "end": "00:02:04.708"
    },
    {
      "text": "說實話",
      "start": "00:02:04.708",
      "end": "00:02:05.333"
    },
    {
      "text": "看起來蘋果真的花了很大的功夫",
      "start": "00:02:05.333",
      "end": "00:02:07.666"
    },
    {
      "text": "去優化 iOS 27 的穩定性和性能表現",
      "start": "00:02:07.666",
      "end": "00:02:10.500"
    },
    {
      "text": "給了特別多數字",
      "start": "00:02:10.500",
      "end": "00:02:12.041"
    },
    {
      "text": "APP 打開快 30%",
      "start": "00:02:12.041",
      "end": "00:02:13.791"
    },
    {
      "text": "照片加載快 70%",
      "start": "00:02:13.791",
      "end": "00:02:15.625"
    },
    {
      "text": "Airdrop 也更快",
      "start": "00:02:15.625",
      "end": "00:02:16.875"
    },
    {
      "text": "網速更快",
      "start": "00:02:16.875",
      "end": "00:02:17.750"
    },
    {
      "text": "檔複製更快",
      "start": "00:02:17.750",
      "end": "00:02:18.750"
    },
    {
      "text": "從 Wifi 切換到蜂窩數據更快",
      "start": "00:02:18.750",
      "end": "00:02:20.666"
    },
    {
      "text": "各種各樣更快",
      "start": "00:02:20.666",
      "end": "00:02:21.875"
    },
    {
      "text": "而且進一步優化了",
      "start": "00:02:21.875",
      "end": "00:02:22.916"
    },
    {
      "text": "iOS 27 在更老設備上的性能表現",
      "start": "00:02:22.916",
      "end": "00:02:25.166"
    },
    {
      "text": "也一路支持到 iPhone 11",
      "start": "00:02:25.166",
      "end": "00:02:26.958"
    },
    {
      "text": "說實話 是該優化優化了",
      "start": "00:02:26.958",
      "end": "00:02:29.125"
    },
    {
      "text": "更新到 iOS 26 以後",
      "start": "00:02:29.125",
      "end": "00:02:30.541"
    },
    {
      "text": "好多人感覺自己的設備都明顯變慢了",
      "start": "00:02:30.541",
      "end": "00:02:33.333"
    },
    {
      "text": "我甚至有朋友",
      "start": "00:02:33.333",
      "end": "00:02:34.250"
    },
    {
      "text": "原本舊的 iPad Pro 用的好好的",
      "start": "00:02:34.250",
      "end": "00:02:36.166"
    },
    {
      "text": "不小心升級之後",
      "start": "00:02:36.166",
      "end": "00:02:37.458"
    },
    {
      "text": "被倒逼換了新的 iPad Pro",
      "start": "00:02:37.458",
      "end": "00:02:39.416"
    },
    {
      "text": "哦 對了",
      "start": "00:02:39.416",
      "end": "00:02:39.791"
    },
    {
      "text": "有一個我萬萬沒有想到",
      "start": "00:02:39.791",
      "end": "00:02:41.000"
    },
    {
      "text": "蘋果會增加的功能",
      "start": "00:02:41.000",
      "end": "00:02:42.541"
    },
    {
      "text": "Airpods 的自定義 EQ 功能",
      "start": "00:02:42.541",
      "end": "00:02:45.041"
    },
    {
      "text": "太好了",
      "start": "00:02:45.041",
      "end": "00:02:45.916"
    },
    {
      "text": "終於啊",
      "start": "00:02:45.916",
      "end": "00:02:46.833"
    },
    {
      "text": "終於可以調整自己 Airpods 的中高低頻了",
      "start": "00:02:46.833",
      "end": "00:02:49.750"
    },
    {
      "text": "差不多主要更新就是這些了",
      "start": "00:02:49.750",
      "end": "00:02:51.541"
    },
    {
      "text": "大部分都是很隱形的",
      "start": "00:02:51.541",
      "end": "00:02:53.208"
    },
    {
      "text": "現在 Beta 還看不太出來",
      "start": "00:02:53.208",
      "end": "00:02:54.750"
    },
    {
      "text": "如果蘋果真的完成了使命",
      "start": "00:02:54.750",
      "end": "00:02:56.750"
    },
    {
      "text": "那麼用舊機的朋友",
      "start": "00:02:56.750",
      "end": "00:02:57.833"
    },
    {
      "text": "應該會慢慢發現的",
      "start": "00:02:57.833",
      "end": "00:02:59.291"
    },
    {
      "text": "除了新系統",
      "start": "00:02:59.291",
      "end": "00:03:00.041"
    },
    {
      "text": "蘋果還花了十幾分鐘介紹了",
      "start": "00:03:00.041",
      "end": "00:03:01.708"
    },
    {
      "text": "全新的兒童和青少年安全功能",
      "start": "00:03:01.708",
      "end": "00:03:04.000"
    },
    {
      "text": "給家長更多的對孩子設備的控制",
      "start": "00:03:04.000",
      "end": "00:03:06.625"
    },
    {
      "text": "安裝什麼樣的 APP",
      "start": "00:03:06.625",
      "end": "00:03:07.541"
    },
    {
      "text": "什麼時間能用",
      "start": "00:03:07.541",
      "end": "00:03:08.625"
    },
    {
      "text": "以及跟誰聊天",
      "start": "00:03:08.625",
      "end": "00:03:09.583"
    },
    {
      "text": "確保孩子能在正確的年紀",
      "start": "00:03:09.583",
      "end": "00:03:11.416"
    },
    {
      "text": "使用正確的 APP",
      "start": "00:03:11.416",
      "end": "00:03:12.500"
    },
    {
      "text": "而且也不會被壞人危害",
      "start": "00:03:12.500",
      "end": "00:03:14.291"
    },
    {
      "text": "我知道",
      "start": "00:03:14.291",
      "end": "00:03:14.791"
    },
    {
      "text": "大部分看這個視頻的觀眾",
      "start": "00:03:14.791",
      "end": "00:03:16.333"
    },
    {
      "text": "不會覺得這個功能很有用",
      "start": "00:03:16.333",
      "end": "00:03:18.125"
    },
    {
      "text": "但是對廣大的消費者來說",
      "start": "00:03:18.125",
      "end": "00:03:19.916"
    },
    {
      "text": "它真的有可能",
      "start": "00:03:19.916",
      "end": "00:03:21.083"
    },
    {
      "text": "是會改變一個孩子的人生軌跡的",
      "start": "00:03:21.083",
      "end": "00:03:23.416"
    },
    {
      "text": "總的來說",
      "start": "00:03:23.416",
      "end": "00:03:23.916"
    },
    {
      "text": "相比於危機四伏的液態玻璃",
      "start": "00:03:23.916",
      "end": "00:03:25.958"
    },
    {
      "text": "新 iOS 27 看起來還是穩紮穩打的",
      "start": "00:03:25.958",
      "end": "00:03:28.625"
    },
    {
      "text": "即便是 Beta 版",
      "start": "00:03:28.625",
      "end": "00:03:29.500"
    },
    {
      "text": "也有不錯的性能和穩定性",
      "start": "00:03:29.500",
      "end": "00:03:31.166"
    },
    {
      "text": "等正式版推出",
      "start": "00:03:31.166",
      "end": "00:03:32.291"
    },
    {
      "text": "我覺得大家都可以考慮儘早升級",
      "start": "00:03:32.291",
      "end": "00:03:34.458"
    },
    {
      "text": "畢竟 鬧鐘這個升級",
      "start": "00:03:34.458",
      "end": "00:03:36.041"
    },
    {
      "text": "還是挺史詩的",
      "start": "00:03:36.041",
      "end": "00:03:37.541"
    },
    {
      "text": "然後就是這次發佈會的核心",
      "start": "00:03:37.541",
      "end": "00:03:39.458"
    },
    {
      "text": "全新 Siri",
      "start": "00:03:39.666",
      "end": "00:03:41.000"
    },
    {
      "text": "名叫 Siri AI",
      "start": "00:03:41.000",
      "end": "00:03:42.666"
    },
    {
      "text": "如果說之前的 Siri 只是一個",
      "start": "00:03:42.666",
      "end": "00:03:44.583"
    },
    {
      "text": "零智能 識別關鍵字的語音遙控器",
      "start": "00:03:44.583",
      "end": "00:03:47.416"
    },
    {
      "text": "那麼新的 Siri 就是一個",
      "start": "00:03:47.416",
      "end": "00:03:48.791"
    },
    {
      "text": "時刻存在 時刻等著被調用",
      "start": "00:03:48.791",
      "end": "00:03:51.125"
    },
    {
      "text": "有記憶 而且會操作 APP 的",
      "start": "00:03:51.125",
      "end": "00:03:52.833"
    },
    {
      "text": "人工智慧助手",
      "start": "00:03:52.833",
      "end": "00:03:54.166"
    },
    {
      "text": "全新 Siri 基於 Google Gemini 的",
      "start": "00:03:54.166",
      "end": "00:03:56.166"
    },
    {
      "text": "技術和模型構建",
      "start": "00:03:56.166",
      "end": "00:03:57.375"
    },
    {
      "text": "現在 直接呼喚 Siri",
      "start": "00:03:57.375",
      "end": "00:03:59.041"
    },
    {
      "text": "或者長按電源鍵",
      "start": "00:03:59.041",
      "end": "00:04:00.375"
    },
    {
      "text": "Siri 就會從靈動島展開",
      "start": "00:04:00.375",
      "end": "00:04:02.416"
    },
    {
      "text": "有一個全新的動畫",
      "start": "00:04:02.416",
      "end": "00:04:03.750"
    },
    {
      "text": "可以顯示圖片 天氣 地點",
      "start": "00:04:03.750",
      "end": "00:04:05.958"
    },
    {
      "text": "還有郵件 備忘錄之類的各種資訊",
      "start": "00:04:05.958",
      "end": "00:04:08.250"
    },
    {
      "text": "話說",
      "start": "00:04:08.250",
      "end": "00:04:08.791"
    },
    {
      "text": "承擔了這麼重大功能的攝像頭挖孔",
      "start": "00:04:08.791",
      "end": "00:04:11.625"
    },
    {
      "text": "蘋果還想不想去掉",
      "start": "00:04:11.625",
      "end": "00:04:13.083"
    },
    {
      "text": "不會永遠待在這裏了吧",
      "start": "00:04:13.083",
      "end": "00:04:15.250"
    },
    {
      "text": "傳統的 Siri 啟動方式",
      "start": "00:04:15.250",
      "end": "00:04:16.500"
    },
    {
      "text": "更適合一些簡單的快問快答",
      "start": "00:04:16.500",
      "end": "00:04:18.458"
    },
    {
      "text": "你還可以在頂上這裏往下滑",
      "start": "00:04:18.458",
      "end": "00:04:20.916"
    },
    {
      "text": "就能換出新的 Siri 詢問輸入框",
      "start": "00:04:20.916",
      "end": "00:04:23.333"
    },
    {
      "text": "在這裏 你可以打字發消息給 Siri",
      "start": "00:04:23.333",
      "end": "00:04:25.500"
    },
    {
      "text": "問一些稍微複雜一點的",
      "start": "00:04:25.500",
      "end": "00:04:26.958"
    },
    {
      "text": "更長一點的事情",
      "start": "00:04:26.958",
      "end": "00:04:28.000"
    },
    {
      "text": "這個時候",
      "start": "00:04:28.000",
      "end": "00:04:28.541"
    },
    {
      "text": "Siri 用起來就會更像一個",
      "start": "00:04:28.541",
      "end": "00:04:30.291"
    },
    {
      "text": "普通的 AI Chatbot",
      "start": "00:04:30.291",
      "end": "00:04:31.833"
    },
    {
      "text": "就像 Chat GPT 豆包什麼的",
      "start": "00:04:31.833",
      "end": "00:04:33.833"
    },
    {
      "text": "實際上",
      "start": "00:04:33.833",
      "end": "00:04:34.375"
    },
    {
      "text": "新 Siri 整個都有點像是",
      "start": "00:04:34.375",
      "end": "00:04:36.375"
    },
    {
      "text": "蘋果出的自己的 Chatbot",
      "start": "00:04:36.375",
      "end": "00:04:38.791"
    },
    {
      "text": "它甚至有自己的 Siri APP",
      "start": "00:04:38.791",
      "end": "00:04:40.791"
    },
    {
      "text": "裏面一打開",
      "start": "00:04:40.791",
      "end": "00:04:41.583"
    },
    {
      "text": "和 Chat GPT 一模一樣",
      "start": "00:04:41.583",
      "end": "00:04:43.208"
    },
    {
      "text": "保存了所有的歷史對話",
      "start": "00:04:43.208",
      "end": "00:04:44.583"
    },
    {
      "text": "還能發送圖片和文件",
      "start": "00:04:44.583",
      "end": "00:04:46.041"
    },
    {
      "text": "也能顯示更複雜的元素",
      "start": "00:04:46.041",
      "end": "00:04:47.416"
    },
    {
      "text": "比如表格什麼的",
      "start": "00:04:47.416",
      "end": "00:04:48.625"
    },
    {
      "text": "在 Mac OS 上",
      "start": "00:04:48.625",
      "end": "00:04:49.458"
    },
    {
      "text": "搜索和提問",
      "start": "00:04:49.458",
      "end": "00:04:50.500"
    },
    {
      "text": "直接取代了原本的 Spotlight",
      "start": "00:04:50.500",
      "end": "00:04:52.291"
    },
    {
      "text": "直接在這裏 該問問該搜搜",
      "start": "00:04:52.291",
      "end": "00:04:54.125"
    },
    {
      "text": "當然",
      "start": "00:04:54.125",
      "end": "00:04:54.583"
    },
    {
      "text": "Siri AI 可以做到",
      "start": "00:04:54.583",
      "end": "00:04:55.875"
    },
    {
      "text": "第三方 Chatbot 做不到的事情",
      "start": "00:04:55.875",
      "end": "00:04:58.041"
    },
    {
      "text": "那就是看到你的手機螢幕",
      "start": "00:04:58.041",
      "end": "00:04:59.916"
    },
    {
      "text": "並且操作你的 APP",
      "start": "00:04:59.916",
      "end": "00:05:01.458"
    },
    {
      "text": "作為一個系統級的 AI",
      "start": "00:05:01.458",
      "end": "00:05:02.958"
    },
    {
      "text": "它可以不需要你一張張截圖",
      "start": "00:05:02.958",
      "end": "00:05:04.791"
    },
    {
      "text": "而是可以直接看到",
      "start": "00:05:04.791",
      "end": "00:05:06.000"
    },
    {
      "text": "你螢幕上顯示的內容",
      "start": "00:05:06.000",
      "end": "00:05:07.500"
    },
    {
      "text": "並且直接幫你進行操作",
      "start": "00:05:07.500",
      "end": "00:05:09.083"
    },
    {
      "text": "而且 Siri 不僅擁有互聯網上的資訊",
      "start": "00:05:09.083",
      "end": "00:05:12.250"
    },
    {
      "text": "它還能直接接入你手機裏 APP 的資訊",
      "start": "00:05:12.250",
      "end": "00:05:15.041"
    },
    {
      "text": "比如你可以問 Siri",
      "start": "00:05:15.041",
      "end": "00:05:16.458"
    },
    {
      "text": "圖上的地點在哪",
      "start": "00:05:16.458",
      "end": "00:05:17.750"
    },
    {
      "text": "還可以繼續問",
      "start": "00:05:17.750",
      "end": "00:05:18.708"
    },
    {
      "text": "我的好朋友張三",
      "start": "00:05:18.708",
      "end": "00:05:19.916"
    },
    {
      "text": "住的離這個地方近嗎",
      "start": "00:05:19.916",
      "end": "00:05:21.291"
    },
    {
      "text": "然後開始導航路線",
      "start": "00:05:21.291",
      "end": "00:05:22.833"
    },
    {
      "text": "途經張三家",
      "start": "00:05:22.833",
      "end": "00:05:24.041"
    },
    {
      "text": "去圖裏這個美麗景色",
      "start": "00:05:24.041",
      "end": "00:05:26.083"
    },
    {
      "text": "在演示裏看著還挺神奇的",
      "start": "00:05:26.083",
      "end": "00:05:28.291"
    },
    {
      "text": "讓我很意外的是",
      "start": "00:05:28.291",
      "end": "00:05:29.375"
    },
    {
      "text": "蘋果在介紹自家 AI 功能的時候",
      "start": "00:05:29.375",
      "end": "00:05:31.625"
    },
    {
      "text": "還不忘拉踩一下那些大模型公司",
      "start": "00:05:31.625",
      "end": "00:05:34.083"
    },
    {
      "text": "人家好歹 AI 已經上線了",
      "start": "00:05:41.500",
      "end": "00:05:43.416"
    },
    {
      "text": "你倒是走出 Beta 版給我用一用啊",
      "start": "00:05:43.416",
      "end": "00:05:46.000"
    },
    {
      "text": "現在更新 iOS 27 Beta 想用新 Siri",
      "start": "00:05:46.083",
      "end": "00:05:48.833"
    },
    {
      "text": "還得加入等候名單呢",
      "start": "00:05:48.833",
      "end": "00:05:51.041"
    },
    {
      "text": "有了新的雲端大模型的幫助",
      "start": "00:05:51.291",
      "end": "00:05:53.083"
    },
    {
      "text": "iOS 的圖片處理能力",
      "start": "00:05:53.083",
      "end": "00:05:54.916"
    },
    {
      "text": "也有了很大的升級",
      "start": "00:05:54.916",
      "end": "00:05:56.000"
    },
    {
      "text": "首先是 iOS 的生圖 APP",
      "start": "00:05:56.000",
      "end": "00:05:58.125"
    },
    {
      "text": "圖樂園",
      "start": "00:05:58.125",
      "end": "00:05:58.958"
    },
    {
      "text": "現在可以生成照片級寫實的圖片了",
      "start": "00:05:58.958",
      "end": "00:06:01.666"
    },
    {
      "text": "而且也有了更好的 AI 圖片後處理",
      "start": "00:06:01.666",
      "end": "00:06:04.208"
    },
    {
      "text": "比如移除圖片裏不想要的東西",
      "start": "00:06:04.208",
      "end": "00:06:06.416"
    },
    {
      "text": "給圖片擴大邊框",
      "start": "00:06:06.416",
      "end": "00:06:07.708"
    },
    {
      "text": "甚至在三維空間裏",
      "start": "00:06:07.708",
      "end": "00:06:09.291"
    },
    {
      "text": "重新調整圖片的構圖",
      "start": "00:06:09.291",
      "end": "00:06:11.250"
    },
    {
      "text": "前面兩個還是很有用的",
      "start": "00:06:11.250",
      "end": "00:06:12.833"
    },
    {
      "text": "但是重新構圖",
      "start": "00:06:12.833",
      "end": "00:06:13.958"
    },
    {
      "text": "效果是挺好的",
      "start": "00:06:13.958",
      "end": "00:06:14.916"
    },
    {
      "text": "但我覺得還是練練構圖吧",
      "start": "00:06:14.916",
      "end": "00:06:17.291"
    },
    {
      "text": "構圖是攝影唯一的樂趣了",
      "start": "00:06:17.291",
      "end": "00:06:19.416"
    },
    {
      "text": "大家注意啊 現在啊",
      "start": "00:06:19.416",
      "end": "00:06:21.375"
    },
    {
      "text": "ISO 100",
      "start": "00:06:21.375",
      "end": "00:06:23.041"
    },
    {
      "text": "光圈 11",
      "start": "00:06:23.208",
      "end": "00:06:24.583"
    },
    {
      "text": "現在開始拍",
      "start": "00:06:24.958",
      "end": "00:06:26.000"
    },
    {
      "text": "再接下來是文本",
      "start": "00:06:26.125",
      "end": "00:06:27.708"
    },
    {
      "text": "也是萬一登錄國行",
      "start": "00:06:27.708",
      "end": "00:06:29.083"
    },
    {
      "text": "我最期待的功能",
      "start": "00:06:29.083",
      "end": "00:06:30.250"
    },
    {
      "text": "我倒不是希望 Siri 來幫我改進寫作",
      "start": "00:06:30.250",
      "end": "00:06:32.541"
    },
    {
      "text": "或者調整語氣什麼的",
      "start": "00:06:32.541",
      "end": "00:06:33.875"
    },
    {
      "text": "我是很眼饞",
      "start": "00:06:33.875",
      "end": "00:06:34.791"
    },
    {
      "text": "新上線的升級版 聽寫",
      "start": "00:06:34.791",
      "end": "00:06:37.333"
    },
    {
      "text": "非常智能",
      "start": "00:06:37.333",
      "end": "00:06:38.083"
    },
    {
      "text": "自動添加標點符號和格式",
      "start": "00:06:38.083",
      "end": "00:06:40.083"
    },
    {
      "text": "如果大家用過一個叫做 Typeless 的軟體",
      "start": "00:06:40.083",
      "end": "00:06:42.375"
    },
    {
      "text": "應該就會懂了",
      "start": "00:06:42.375",
      "end": "00:06:43.291"
    },
    {
      "text": "比打字快一萬倍",
      "start": "00:06:43.291",
      "end": "00:06:45.125"
    },
    {
      "text": "但是 Typeless 免費版",
      "start": "00:06:45.125",
      "end": "00:06:46.791"
    },
    {
      "text": "一周限制 8000 個詞",
      "start": "00:06:46.791",
      "end": "00:06:48.541"
    },
    {
      "text": "Siri 聽寫如果是免費",
      "start": "00:06:48.541",
      "end": "00:06:50.333"
    },
    {
      "text": "那可就造福大眾了",
      "start": "00:06:50.333",
      "end": "00:06:52.166"
    },
    {
      "text": "還有一個可能用的不多",
      "start": "00:06:52.166",
      "end": "00:06:53.666"
    },
    {
      "text": "但是蘋果希望 AI",
      "start": "00:06:53.666",
      "end": "00:06:55.083"
    },
    {
      "text": "可以幫大家多用一用的 APP",
      "start": "00:06:55.083",
      "end": "00:06:57.291"
    },
    {
      "text": "蘋果官方的快捷自動化",
      "start": "00:06:58.333",
      "end": "00:07:00.750"
    },
    {
      "text": "現在允許直接用自然語言描述需求",
      "start": "00:07:00.750",
      "end": "00:07:03.208"
    },
    {
      "text": "AI 幫你實現 Shortcut 功能",
      "start": "00:07:03.208",
      "end": "00:07:05.041"
    },
    {
      "text": "這應該算是一種",
      "start": "00:07:05.041",
      "end": "00:07:06.500"
    },
    {
      "text": "青春版的 Vibe Coding",
      "start": "00:07:06.500",
      "end": "00:07:08.625"
    },
    {
      "text": "好",
      "start": "00:07:08.666",
      "end": "00:07:09.375"
    },
    {
      "text": "這就是今年開發者大會上",
      "start": "00:07:09.375",
      "end": "00:07:10.916"
    },
    {
      "text": "蘋果全家桶的所有重要軟體更新了",
      "start": "00:07:10.916",
      "end": "00:07:14.291"
    },
    {
      "text": "除了大家一時半會用不上的 AI 功能",
      "start": "00:07:14.291",
      "end": "00:07:16.500"
    },
    {
      "text": "都是小修小補",
      "start": "00:07:16.500",
      "end": "00:07:18.083"
    },
    {
      "text": "雖然不怎麼讓人心潮澎湃",
      "start": "00:07:18.083",
      "end": "00:07:20.291"
    },
    {
      "text": "但是長期",
      "start": "00:07:20.291",
      "end": "00:07:21.083"
    },
    {
      "text": "應該還是對大家有幫助的",
      "start": "00:07:21.083",
      "end": "00:07:22.791"
    },
    {
      "text": "以及就像視頻一開頭說的",
      "start": "00:07:22.791",
      "end": "00:07:24.541"
    },
    {
      "text": "今年的發佈會挺特別的",
      "start": "00:07:24.541",
      "end": "00:07:26.666"
    },
    {
      "text": "這是 Tim Cook 在 9 月 1 日正式卸任之前",
      "start": "00:07:26.666",
      "end": "00:07:29.791"
    },
    {
      "text": "最後一次以 CEO 的身份主持發佈會了",
      "start": "00:07:29.791",
      "end": "00:07:32.875"
    },
    {
      "text": "不管你對他掌舵下的蘋果",
      "start": "00:07:32.875",
      "end": "00:07:34.625"
    },
    {
      "text": "所產出的產品",
      "start": "00:07:34.625",
      "end": "00:07:35.583"
    },
    {
      "text": "有怎樣的看法",
      "start": "00:07:35.583",
      "end": "00:07:36.625"
    },
    {
      "text": "他都是這個時代最厲害的 CEO 之一",
      "start": "00:07:36.625",
      "end": "00:07:39.541"
    },
    {
      "text": "謹以此曲表達我對 Tim 的想念吧",
      "start": "00:07:39.541",
      "end": "00:07:42.375"
    }
  ]
}
