{
  "schema": "tsumugu/transcript-cues@1",
  "lang": "zh-Hant",
  "source": "transcript:ai-replaced-my-thinking.zh-Hant.vtt",
  "videoId": "_EmMwEIqAwo",
  "cues": [
    {
      "text": "用 AI",
      "start": "00:00:00.000",
      "end": "00:00:00.666"
    },
    {
      "text": "真的會讓人變笨嗎",
      "start": "00:00:00.666",
      "end": "00:00:02.400"
    },
    {
      "text": "出於強烈的好奇",
      "start": "00:00:02.400",
      "end": "00:00:03.600"
    },
    {
      "text": "我決定對自己做一個人體實驗",
      "start": "00:00:03.600",
      "end": "00:00:06.166"
    },
    {
      "text": "我會把工作和思考",
      "start": "00:00:06.166",
      "end": "00:00:07.800"
    },
    {
      "text": "全都外包給 AI",
      "start": "00:00:07.800",
      "end": "00:00:09.433"
    },
    {
      "text": "同時再消費 AI 生成的文化產品",
      "start": "00:00:09.433",
      "end": "00:00:12.400"
    },
    {
      "text": "每天至少 4 小時高強度使用",
      "start": "00:00:12.400",
      "end": "00:00:14.566"
    },
    {
      "text": "一周後",
      "start": "00:00:14.566",
      "end": "00:00:15.266"
    },
    {
      "text": "分別從神經科學和心理學兩個層面",
      "start": "00:00:15.266",
      "end": "00:00:18.300"
    },
    {
      "text": "看看我的大腦會發生什麼變化",
      "start": "00:00:18.333",
      "end": "00:00:20.800"
    },
    {
      "text": "我的智力真的會下降嗎",
      "start": "00:00:20.800",
      "end": "00:00:23.666"
    },
    {
      "text": "怎麼也睡不著",
      "start": "00:00:24.466",
      "end": "00:00:25.600"
    },
    {
      "text": "我好無語",
      "start": "00:00:25.600",
      "end": "00:00:26.766"
    },
    {
      "text": "為了給我的大腦和智力",
      "start": "00:00:27.133",
      "end": "00:00:28.800"
    },
    {
      "text": "做一個基準測試",
      "start": "00:00:28.800",
      "end": "00:00:30.166"
    },
    {
      "text": "我來到了",
      "start": "00:00:30.166",
      "end": "00:00:30.766"
    },
    {
      "text": "上海大學附屬全景醫學影像診斷中心",
      "start": "00:00:30.766",
      "end": "00:00:33.566"
    },
    {
      "text": "這裏有非常先進的 MR 檢查機器",
      "start": "00:00:33.566",
      "end": "00:00:35.966"
    },
    {
      "text": "和專業的醫生團隊",
      "start": "00:00:35.966",
      "end": "00:00:37.166"
    },
    {
      "text": "可以很好的觀測我的大腦",
      "start": "00:00:37.166",
      "end": "00:00:38.933"
    },
    {
      "text": "這就是我當時的大腦",
      "start": "00:00:38.933",
      "end": "00:00:40.766"
    },
    {
      "text": "醫生說十分活躍",
      "start": "00:00:40.766",
      "end": "00:00:42.266"
    },
    {
      "text": "非常健康",
      "start": "00:00:42.266",
      "end": "00:00:43.333"
    },
    {
      "text": "然後是智力測試",
      "start": "00:00:43.333",
      "end": "00:00:44.800"
    },
    {
      "text": "小夥伴們給我準備的",
      "start": "00:00:44.800",
      "end": "00:00:46.066"
    },
    {
      "text": "是瑞文高級推理測試",
      "start": "00:00:46.066",
      "end": "00:00:47.966"
    },
    {
      "text": "這是一套專門測量邏輯和反應的",
      "start": "00:00:47.966",
      "end": "00:00:50.200"
    },
    {
      "text": "流體智力試題",
      "start": "00:00:50.200",
      "end": "00:00:51.533"
    },
    {
      "text": "題目看起來有點像公務員行測題",
      "start": "00:00:51.533",
      "end": "00:00:53.833"
    },
    {
      "text": "36 道題",
      "start": "00:00:53.833",
      "end": "00:00:54.566"
    },
    {
      "text": "難度逐漸遞增",
      "start": "00:00:54.566",
      "end": "00:00:55.800"
    },
    {
      "text": "有的只有加法和抵消",
      "start": "00:00:55.800",
      "end": "00:00:57.933"
    },
    {
      "text": "有的會加入旋轉 移動 頻率等",
      "start": "00:00:57.933",
      "end": "00:01:00.666"
    },
    {
      "text": "多種邏輯疊加起來考你",
      "start": "00:01:00.666",
      "end": "00:01:02.566"
    },
    {
      "text": "在越短的時間內答對越多的題",
      "start": "00:01:02.566",
      "end": "00:01:04.266"
    },
    {
      "text": "就越好",
      "start": "00:01:04.266",
      "end": "00:01:05.066"
    },
    {
      "text": "做完了",
      "start": "00:01:07.500",
      "end": "00:01:08.300"
    },
    {
      "text": "我錯了一道題啊居然",
      "start": "00:01:09.000",
      "end": "00:01:10.600"
    },
    {
      "text": "這個就是我現在的水準",
      "start": "00:01:10.766",
      "end": "00:01:12.533"
    },
    {
      "text": "感覺 7 天之後",
      "start": "00:01:12.533",
      "end": "00:01:13.933"
    },
    {
      "text": "我必會變笨啊",
      "start": "00:01:14.133",
      "end": "00:01:15.333"
    },
    {
      "text": "總之這些就是參照組了",
      "start": "00:01:15.333",
      "end": "00:01:17.166"
    },
    {
      "text": "實驗開始",
      "start": "00:01:17.166",
      "end": "00:01:18.366"
    },
    {
      "text": "伴隨著中午的第一聲鳥叫",
      "start": "00:01:21.066",
      "end": "00:01:23.366"
    },
    {
      "text": "我起床了",
      "start": "00:01:23.566",
      "end": "00:01:24.933"
    },
    {
      "text": "我醒來以後的第一件事情就是點外賣",
      "start": "00:01:25.000",
      "end": "00:01:27.166"
    },
    {
      "text": "這個呢就可以交給 AI",
      "start": "00:01:27.166",
      "end": "00:01:28.533"
    },
    {
      "text": "我今天想吃健康一點的",
      "start": "00:01:28.533",
      "end": "00:01:30.766"
    },
    {
      "text": "少油少鹽",
      "start": "00:01:30.766",
      "end": "00:01:31.366"
    },
    {
      "text": "要給 AI 下需求",
      "start": "00:01:31.366",
      "end": "00:01:32.433"
    },
    {
      "text": "什麼菜系什麼距離",
      "start": "00:01:32.433",
      "end": "00:01:33.666"
    },
    {
      "text": "什麼價位",
      "start": "00:01:33.666",
      "end": "00:01:34.333"
    },
    {
      "text": "說實話",
      "start": "00:01:34.333",
      "end": "00:01:34.866"
    },
    {
      "text": "光是說這麼多話",
      "start": "00:01:34.866",
      "end": "00:01:35.866"
    },
    {
      "text": "也挺麻煩的",
      "start": "00:01:35.866",
      "end": "00:01:37.066"
    },
    {
      "text": "不對",
      "start": "00:01:37.566",
      "end": "00:01:38.366"
    },
    {
      "text": "實驗開始好像就不能再玩《殺戮尖塔2》了",
      "start": "00:01:39.233",
      "end": "00:01:42.266"
    },
    {
      "text": "說起來要不是因為做這個實驗",
      "start": "00:01:42.533",
      "end": "00:01:44.133"
    },
    {
      "text": "我還真的沒有想過",
      "start": "00:01:44.133",
      "end": "00:01:45.533"
    },
    {
      "text": "我們在家 出門 工作 娛樂",
      "start": "00:01:45.533",
      "end": "00:01:48.600"
    },
    {
      "text": "人的一天究竟會做多少種思考",
      "start": "00:01:48.600",
      "end": "00:01:51.433"
    },
    {
      "text": "心理學上有這樣一個理論",
      "start": "00:01:51.433",
      "end": "00:01:53.166"
    },
    {
      "text": "說人的大腦有兩套思考系統",
      "start": "00:01:53.166",
      "end": "00:01:55.733"
    },
    {
      "text": "一套快一套慢",
      "start": "00:01:55.733",
      "end": "00:01:57.166"
    },
    {
      "text": "像說話認字洗漱喂貓拿外賣",
      "start": "00:01:57.166",
      "end": "00:02:00.133"
    },
    {
      "text": "這些幾乎不費力的直覺類思考",
      "start": "00:02:00.133",
      "end": "00:02:02.733"
    },
    {
      "text": "叫做快思考",
      "start": "00:02:02.733",
      "end": "00:02:03.833"
    },
    {
      "text": "而像決定今天吃什麼",
      "start": "00:02:03.833",
      "end": "00:02:05.633"
    },
    {
      "text": "今天穿什麼",
      "start": "00:02:05.633",
      "end": "00:02:06.900"
    },
    {
      "text": "以及完成工作",
      "start": "00:02:07.133",
      "end": "00:02:10.533"
    },
    {
      "text": "這些需要注意力",
      "start": "00:02:10.533",
      "end": "00:02:11.833"
    },
    {
      "text": "需要動腦推理判斷的思考",
      "start": "00:02:11.833",
      "end": "00:02:13.800"
    },
    {
      "text": "叫做慢思考",
      "start": "00:02:13.800",
      "end": "00:02:14.966"
    },
    {
      "text": "這也是最容易外包給 AI 的部分",
      "start": "00:02:14.966",
      "end": "00:02:17.733"
    },
    {
      "text": "今天的慢思考有",
      "start": "00:02:17.733",
      "end": "00:02:19.133"
    },
    {
      "text": "想選題 完成甲方的大綱",
      "start": "00:02:19.266",
      "end": "00:02:21.433"
    },
    {
      "text": "拍攝 開日常會議",
      "start": "00:02:21.433",
      "end": "00:02:23.233"
    },
    {
      "text": "除了拍攝要我本人",
      "start": "00:02:23.233",
      "end": "00:02:24.466"
    },
    {
      "text": "其他的似乎 AI 都可以做",
      "start": "00:02:24.466",
      "end": "00:02:26.266"
    },
    {
      "text": "之前我有提到",
      "start": "00:02:26.266",
      "end": "00:02:27.400"
    },
    {
      "text": "Claude 還挺懂互聯網的",
      "start": "00:02:27.400",
      "end": "00:02:29.266"
    },
    {
      "text": "可以讓 ta 模仿我的風格",
      "start": "00:02:29.266",
      "end": "00:02:30.733"
    },
    {
      "text": "提出選題",
      "start": "00:02:30.733",
      "end": "00:02:31.633"
    },
    {
      "text": "同時給出大綱",
      "start": "00:02:31.633",
      "end": "00:02:32.800"
    },
    {
      "text": "貪玩歌姬小寧子頻道的選題",
      "start": "00:02:32.800",
      "end": "00:02:35.233"
    },
    {
      "text": "AI 在思考的時候",
      "start": "00:02:35.233",
      "end": "00:02:36.400"
    },
    {
      "text": "我可以去拍攝",
      "start": "00:02:36.400",
      "end": "00:02:37.500"
    },
    {
      "text": "我其實對這個實驗有一個疑問",
      "start": "00:02:44.366",
      "end": "00:02:46.400"
    },
    {
      "text": "就是我們的模具已經自帶開口",
      "start": "00:02:46.400",
      "end": "00:02:48.533"
    },
    {
      "text": "那我保鮮膜的意義在哪里",
      "start": "00:02:48.533",
      "end": "00:02:51.400"
    },
    {
      "text": "我問一下 AI",
      "start": "00:02:52.166",
      "end": "00:02:53.333"
    },
    {
      "text": "事實證明",
      "start": "00:02:53.733",
      "end": "00:02:54.400"
    },
    {
      "text": "還是真人專家說的更對",
      "start": "00:02:54.400",
      "end": "00:02:56.333"
    },
    {
      "text": "當時拍的那段實驗素材",
      "start": "00:02:56.333",
      "end": "00:02:57.766"
    },
    {
      "text": "後來全部推倒重做了",
      "start": "00:02:57.766",
      "end": "00:02:59.600"
    },
    {
      "text": "回到辦公室",
      "start": "00:03:04.600",
      "end": "00:03:05.533"
    },
    {
      "text": "我就可以採摘 Claude 的勞動果實",
      "start": "00:03:05.533",
      "end": "00:03:08.000"
    },
    {
      "text": "乍一看反正字挺多的",
      "start": "00:03:08.000",
      "end": "00:03:09.633"
    },
    {
      "text": "明天的選題會",
      "start": "00:03:09.633",
      "end": "00:03:10.733"
    },
    {
      "text": "算是準備好了",
      "start": "00:03:10.733",
      "end": "00:03:12.200"
    },
    {
      "text": "給甲方交大綱啊",
      "start": "00:03:12.333",
      "end": "00:03:13.766"
    },
    {
      "text": "也差不多",
      "start": "00:03:13.766",
      "end": "00:03:14.666"
    },
    {
      "text": "上傳檔",
      "start": "00:03:14.666",
      "end": "00:03:15.566"
    },
    {
      "text": "讓 AI 看完總結出需求",
      "start": "00:03:15.566",
      "end": "00:03:17.400"
    },
    {
      "text": "再讓它自動寫出大綱",
      "start": "00:03:17.400",
      "end": "00:03:19.000"
    },
    {
      "text": "填進表格",
      "start": "00:03:19.000",
      "end": "00:03:20.000"
    },
    {
      "text": "生成可以直接下載的檔",
      "start": "00:03:20.000",
      "end": "00:03:21.833"
    },
    {
      "text": "提交",
      "start": "00:03:21.833",
      "end": "00:03:22.433"
    },
    {
      "text": "搞定",
      "start": "00:03:22.433",
      "end": "00:03:23.200"
    },
    {
      "text": "做完了今天的工作",
      "start": "00:03:23.566",
      "end": "00:03:25.166"
    },
    {
      "text": "哈哈哈",
      "start": "00:03:25.233",
      "end": "00:03:26.033"
    },
    {
      "text": "這裏需要說明一下",
      "start": "00:03:26.066",
      "end": "00:03:27.166"
    },
    {
      "text": "在開始這個實驗之前",
      "start": "00:03:27.166",
      "end": "00:03:28.400"
    },
    {
      "text": "我其實已經把重要的編導工作",
      "start": "00:03:28.400",
      "end": "00:03:30.733"
    },
    {
      "text": "提前給做完了",
      "start": "00:03:30.733",
      "end": "00:03:31.966"
    },
    {
      "text": "以及我們平時做任何視頻",
      "start": "00:03:31.966",
      "end": "00:03:33.233"
    },
    {
      "text": "都不會直接使用 AI 生成的大綱和成稿",
      "start": "00:03:33.233",
      "end": "00:03:35.966"
    },
    {
      "text": "請大家放心",
      "start": "00:03:35.966",
      "end": "00:03:37.466"
    },
    {
      "text": "平時",
      "start": "00:03:37.466",
      "end": "00:03:38.133"
    },
    {
      "text": "我還需要給 Playfull 新產品提提意見",
      "start": "00:03:38.133",
      "end": "00:03:40.566"
    },
    {
      "text": "沒想到",
      "start": "00:03:40.566",
      "end": "00:03:41.466"
    },
    {
      "text": "GPT 在這裏還真挺有用的",
      "start": "00:03:41.466",
      "end": "00:03:44.333"
    },
    {
      "text": "適合做黑白組合銷售",
      "start": "00:03:44.333",
      "end": "00:03:46.300"
    },
    {
      "text": "銷量僅次於黑色款",
      "start": "00:03:46.333",
      "end": "00:03:48.133"
    },
    {
      "text": "如果說選 T 恤的圖案",
      "start": "00:03:48.433",
      "end": "00:03:50.000"
    },
    {
      "text": "AI 只算是跟人類對對答案",
      "start": "00:03:50.000",
      "end": "00:03:51.833"
    },
    {
      "text": "那給包裝盒提修改意見",
      "start": "00:03:51.833",
      "end": "00:03:54.066"
    },
    {
      "text": "AI 真能算是專家",
      "start": "00:03:54.066",
      "end": "00:03:55.833"
    },
    {
      "text": "直接提出了英文用詞不准確",
      "start": "00:03:55.833",
      "end": "00:03:57.966"
    },
    {
      "text": "產品 feature 沒有寫清這些致命的問題",
      "start": "00:03:57.966",
      "end": "00:04:00.466"
    },
    {
      "text": "包裝設計",
      "start": "00:04:00.466",
      "end": "00:04:01.533"
    },
    {
      "text": "對我來說是完全陌生的行業",
      "start": "00:04:01.533",
      "end": "00:04:03.633"
    },
    {
      "text": "它有自己通用的標準",
      "start": "00:04:03.633",
      "end": "00:04:05.066"
    },
    {
      "text": "也有很多前人的經驗",
      "start": "00:04:05.066",
      "end": "00:04:06.666"
    },
    {
      "text": "我看老闆這個崗位完全可以被 AI 代替",
      "start": "00:04:06.666",
      "end": "00:04:10.033"
    },
    {
      "text": "一天的工作差不多就到這了",
      "start": "00:04:10.033",
      "end": "00:04:12.166"
    },
    {
      "text": "AI 確實在幾分鐘的時間裏",
      "start": "00:04:12.166",
      "end": "00:04:13.966"
    },
    {
      "text": "就把我平時要花一整天",
      "start": "00:04:13.966",
      "end": "00:04:15.533"
    },
    {
      "text": "才能做完的腦力勞動",
      "start": "00:04:15.533",
      "end": "00:04:16.933"
    },
    {
      "text": "全都給",
      "start": "00:04:16.933",
      "end": "00:04:17.733"
    },
    {
      "text": "這一天下來",
      "start": "00:04:18.533",
      "end": "00:04:19.400"
    },
    {
      "text": "我幾乎沒有動腦",
      "start": "00:04:19.400",
      "end": "00:04:21.166"
    },
    {
      "text": "一點都不累",
      "start": "00:04:21.166",
      "end": "00:04:22.600"
    },
    {
      "text": "但就也沒有平時那種",
      "start": "00:04:22.633",
      "end": "00:04:25.366"
    },
    {
      "text": "耶",
      "start": "00:04:25.366",
      "end": "00:04:25.800"
    },
    {
      "text": "今天的我好棒棒",
      "start": "00:04:25.800",
      "end": "00:04:27.166"
    },
    {
      "text": "的那種成就感",
      "start": "00:04:27.166",
      "end": "00:04:28.700"
    },
    {
      "text": "給我講一個",
      "start": "00:04:28.733",
      "end": "00:04:29.966"
    },
    {
      "text": "開心的睡前故事",
      "start": "00:04:29.966",
      "end": "00:04:31.900"
    },
    {
      "text": "我是京圈薑家大小姐",
      "start": "00:04:32.033",
      "end": "00:04:34.000"
    },
    {
      "text": "閉關三年",
      "start": "00:04:34.000",
      "end": "00:04:35.033"
    },
    {
      "text": "攻克了困擾全球的量子通信難題",
      "start": "00:04:35.033",
      "end": "00:04:37.766"
    },
    {
      "text": "第二天",
      "start": "00:04:41.100",
      "end": "00:04:41.866"
    },
    {
      "text": "我們要再徹底一點",
      "start": "00:04:41.866",
      "end": "00:04:43.533"
    },
    {
      "text": "讓 AI 替我管人",
      "start": "00:04:43.533",
      "end": "00:04:45.400"
    },
    {
      "text": "所以當然",
      "start": "00:04:45.400",
      "end": "00:04:46.166"
    },
    {
      "text": "我也部署了 Open Claw",
      "start": "00:04:46.166",
      "end": "00:04:47.633"
    },
    {
      "text": "去執行一些瑣碎的工作",
      "start": "00:04:47.633",
      "end": "00:04:49.600"
    },
    {
      "text": "ta 果然不負眾望的",
      "start": "00:04:49.600",
      "end": "00:04:51.766"
    },
    {
      "text": "啥也沒幹成",
      "start": "00:04:52.333",
      "end": "00:04:53.133"
    },
    {
      "text": "最後他又變成一個",
      "start": "00:04:53.133",
      "end": "00:04:54.233"
    },
    {
      "text": "提醒同事們喝水的樂子機器人",
      "start": "00:04:54.233",
      "end": "00:04:56.266"
    },
    {
      "text": "不過還好",
      "start": "00:04:56.266",
      "end": "00:04:57.366"
    },
    {
      "text": "昨天讓 Claude 準備的 10 個選題裏面",
      "start": "00:04:57.366",
      "end": "00:04:59.633"
    },
    {
      "text": "有兩到三個都得到了大家的肯定",
      "start": "00:04:59.633",
      "end": "00:05:02.000"
    },
    {
      "text": "嗯",
      "start": "00:05:02.000",
      "end": "00:05:02.633"
    },
    {
      "text": "真的很強",
      "start": "00:05:02.733",
      "end": "00:05:03.666"
    },
    {
      "text": "編導們應該會有危機感",
      "start": "00:05:03.666",
      "end": "00:05:05.833"
    },
    {
      "text": "而在現場念出 AI 創意的我",
      "start": "00:05:05.833",
      "end": "00:05:08.000"
    },
    {
      "text": "也很像一個在模擬上班的機器人",
      "start": "00:05:08.000",
      "end": "00:05:10.833"
    },
    {
      "text": "當選題被質疑的時候",
      "start": "00:05:10.833",
      "end": "00:05:12.433"
    },
    {
      "text": "我能做的",
      "start": "00:05:12.433",
      "end": "00:05:13.200"
    },
    {
      "text": "只有趕緊從 AI 寫的大綱裏",
      "start": "00:05:13.200",
      "end": "00:05:14.800"
    },
    {
      "text": "找現成的答案",
      "start": "00:05:14.800",
      "end": "00:05:16.166"
    },
    {
      "text": "ClauA夢 你要幫幫我",
      "start": "00:05:16.666",
      "end": "00:05:18.866"
    },
    {
      "text": "AI 替我工作以後",
      "start": "00:05:18.933",
      "end": "00:05:20.166"
    },
    {
      "text": "上班就會變得很閑",
      "start": "00:05:20.166",
      "end": "00:05:21.866"
    },
    {
      "text": "我開始刷 AI 生成視頻",
      "start": "00:05:21.866",
      "end": "00:05:24.400"
    },
    {
      "text": "我記得",
      "start": "00:05:25.000",
      "end": "00:05:25.733"
    },
    {
      "text": "當我第一次聽說這只柴犬倉鼠的時候",
      "start": "00:05:25.733",
      "end": "00:05:29.366"
    },
    {
      "text": "我的表情是這樣的",
      "start": "00:05:29.366",
      "end": "00:05:30.966"
    },
    {
      "text": "當我決定這幾天都要看它的時候",
      "start": "00:05:31.766",
      "end": "00:05:34.000"
    },
    {
      "text": "我的表情是這樣的",
      "start": "00:05:34.000",
      "end": "00:05:35.866"
    },
    {
      "text": "而當我真的看它的時候",
      "start": "00:05:37.066",
      "end": "00:05:38.933"
    },
    {
      "text": "除了我的刀盾 bibilabu 還有",
      "start": "00:05:41.633",
      "end": "00:05:44.133"
    },
    {
      "text": "這些就是國外比較火的 AI Slop 明星",
      "start": "00:05:47.866",
      "end": "00:05:51.166"
    },
    {
      "text": "圍繞這些明星",
      "start": "00:05:51.166",
      "end": "00:05:52.466"
    },
    {
      "text": "有特別多短視頻被生成出來",
      "start": "00:05:52.466",
      "end": "00:05:54.733"
    },
    {
      "text": "如果你好奇",
      "start": "00:05:54.733",
      "end": "00:05:55.533"
    },
    {
      "text": "當我們在看這種低質內容的時候",
      "start": "00:05:55.533",
      "end": "00:05:57.600"
    },
    {
      "text": "我們的大腦是怎麼樣的",
      "start": "00:05:57.600",
      "end": "00:05:59.433"
    },
    {
      "text": "這個是測量大腦皮層即時血氧濃度的設備",
      "start": "00:05:59.433",
      "end": "00:06:02.733"
    },
    {
      "text": "非常適合看額葉的狀態",
      "start": "00:06:02.733",
      "end": "00:06:04.466"
    },
    {
      "text": "我先是看了 10 分鐘的紀錄片",
      "start": "00:06:04.466",
      "end": "00:06:06.566"
    },
    {
      "text": "作為對照組",
      "start": "00:06:06.566",
      "end": "00:06:07.533"
    },
    {
      "text": "然後我又看了 10 分鐘 AI Slop",
      "start": "00:06:07.533",
      "end": "00:06:09.833"
    },
    {
      "text": "整個過程我都儘量做到了只被動接收",
      "start": "00:06:09.833",
      "end": "00:06:12.733"
    },
    {
      "text": "不主動思考",
      "start": "00:06:12.733",
      "end": "00:06:14.000"
    },
    {
      "text": "然後結果是這樣的",
      "start": "00:06:14.000",
      "end": "00:06:16.566"
    },
    {
      "text": "看兩種內容的時候",
      "start": "00:06:16.566",
      "end": "00:06:17.766"
    },
    {
      "text": "前額葉總耗氧量差不多",
      "start": "00:06:17.766",
      "end": "00:06:19.566"
    },
    {
      "text": "說明都有在工作",
      "start": "00:06:19.566",
      "end": "00:06:20.733"
    },
    {
      "text": "但是看紀錄片的時候",
      "start": "00:06:20.733",
      "end": "00:06:22.600"
    },
    {
      "text": "靠上的區域耗氧量更多",
      "start": "00:06:22.600",
      "end": "00:06:24.433"
    },
    {
      "text": "這些區域負責像是維持專注啊",
      "start": "00:06:24.433",
      "end": "00:06:26.666"
    },
    {
      "text": "工作記憶 任務控制之類的思維功能",
      "start": "00:06:26.666",
      "end": "00:06:29.333"
    },
    {
      "text": "而在看 AI Slop 時",
      "start": "00:06:29.333",
      "end": "00:06:30.733"
    },
    {
      "text": "靠下的區域啟動的更多",
      "start": "00:06:30.733",
      "end": "00:06:32.566"
    },
    {
      "text": "這代表我被內容牽引",
      "start": "00:06:32.566",
      "end": "00:06:34.233"
    },
    {
      "text": "在做更被動更快速的選擇和切換",
      "start": "00:06:34.233",
      "end": "00:06:37.266"
    },
    {
      "text": "Ballerina cappuccino",
      "start": "00:06:37.466",
      "end": "00:06:39.200"
    },
    {
      "text": "這些倒還比較符合常識",
      "start": "00:06:39.833",
      "end": "00:06:41.666"
    },
    {
      "text": "但如果我們關注大腦的資源調度",
      "start": "00:06:41.666",
      "end": "00:06:44.666"
    },
    {
      "text": "就會發現",
      "start": "00:06:44.666",
      "end": "00:06:45.733"
    },
    {
      "text": "看 AI Slop 時",
      "start": "00:06:45.733",
      "end": "00:06:46.833"
    },
    {
      "text": "我的額葉看起來",
      "start": "00:06:46.833",
      "end": "00:06:48.566"
    },
    {
      "text": "像是老化了",
      "start": "00:06:48.633",
      "end": "00:06:50.266"
    },
    {
      "text": "灰灰的一片",
      "start": "00:06:50.366",
      "end": "00:06:51.166"
    },
    {
      "text": "說明大腦幾乎沒有進行資源調度",
      "start": "00:06:51.166",
      "end": "00:06:53.366"
    },
    {
      "text": "做的都是無效思考",
      "start": "00:06:53.366",
      "end": "00:06:55.133"
    },
    {
      "text": "而看紀錄片的時候",
      "start": "00:06:55.133",
      "end": "00:06:56.200"
    },
    {
      "text": "我的大腦抑制了藍色的區域",
      "start": "00:06:56.200",
      "end": "00:06:57.866"
    },
    {
      "text": "把資源都調度給紅色區域",
      "start": "00:06:57.866",
      "end": "00:07:00.000"
    },
    {
      "text": "這說明它在做有目的的有效思考",
      "start": "00:07:00.000",
      "end": "00:07:02.866"
    },
    {
      "text": "還好 AI Slop 在國內不算火",
      "start": "00:07:02.866",
      "end": "00:07:05.800"
    },
    {
      "text": "國內火的",
      "start": "00:07:05.800",
      "end": "00:07:06.800"
    },
    {
      "text": "是",
      "start": "00:07:08.766",
      "end": "00:07:09.433"
    },
    {
      "text": "AI 漫劇",
      "start": "00:07:09.433",
      "end": "00:07:10.800"
    },
    {
      "text": "調暗燈光",
      "start": "00:07:11.433",
      "end": "00:07:12.366"
    },
    {
      "text": "我來狠狠品鑒一把",
      "start": "00:07:12.366",
      "end": "00:07:14.266"
    },
    {
      "text": "這些內容",
      "start": "00:07:14.266",
      "end": "00:07:14.966"
    },
    {
      "text": "本質是把原本沒有條件動畫化",
      "start": "00:07:14.966",
      "end": "00:07:17.366"
    },
    {
      "text": "或者真人化的網文",
      "start": "00:07:17.366",
      "end": "00:07:18.633"
    },
    {
      "text": "用低廉的 AI 方案讓它們變成視頻",
      "start": "00:07:18.633",
      "end": "00:07:20.633"
    },
    {
      "text": "呃多少算是動起來了",
      "start": "00:07:20.633",
      "end": "00:07:22.966"
    },
    {
      "text": "一開始看",
      "start": "00:07:22.966",
      "end": "00:07:23.833"
    },
    {
      "text": "我還有些羞恥",
      "start": "00:07:23.833",
      "end": "00:07:25.133"
    },
    {
      "text": "到後來我已經感覺不到羞恥了",
      "start": "00:07:25.166",
      "end": "00:07:28.100"
    },
    {
      "text": "是的我回到家之後也在看",
      "start": "00:07:30.600",
      "end": "00:07:33.500"
    },
    {
      "text": "結果",
      "start": "00:07:33.600",
      "end": "00:07:34.400"
    },
    {
      "text": "現在是",
      "start": "00:07:34.400",
      "end": "00:07:35.466"
    },
    {
      "text": "現在是下午的 12 點半",
      "start": "00:07:35.866",
      "end": "00:07:38.366"
    },
    {
      "text": "但是我",
      "start": "00:07:41.000",
      "end": "00:07:41.933"
    },
    {
      "text": "但是我早上 9 點鐘才睡著",
      "start": "00:07:42.000",
      "end": "00:07:44.666"
    },
    {
      "text": "太痛苦了",
      "start": "00:07:44.666",
      "end": "00:07:45.600"
    },
    {
      "text": "持續接受",
      "start": "00:07:45.600",
      "end": "00:07:46.466"
    },
    {
      "text": "碎片化 高刺激 邏輯不嚴密的內容之後",
      "start": "00:07:46.466",
      "end": "00:07:49.066"
    },
    {
      "text": "我完全失眠了",
      "start": "00:07:49.066",
      "end": "00:07:50.833"
    },
    {
      "text": "當天還發生了走錯路",
      "start": "00:07:50.833",
      "end": "00:07:52.633"
    },
    {
      "text": "記不住自己要幹嘛的情況",
      "start": "00:07:52.633",
      "end": "00:07:54.000"
    },
    {
      "text": "哎呀我好無語啊",
      "start": "00:07:54.000",
      "end": "00:07:55.600"
    },
    {
      "text": "當然這跟通宵應該也很有關系啊",
      "start": "00:07:55.600",
      "end": "00:07:58.166"
    },
    {
      "text": "不妙了呀",
      "start": "00:07:58.166",
      "end": "00:07:59.133"
    },
    {
      "text": "還好那天是雙休日",
      "start": "00:07:59.133",
      "end": "00:08:00.266"
    },
    {
      "text": "本來就不太會進行思考",
      "start": "00:08:00.266",
      "end": "00:08:02.000"
    },
    {
      "text": "我能想到最重要的思考就是",
      "start": "00:08:02.000",
      "end": "00:08:04.900"
    },
    {
      "text": "找餐廳",
      "start": "00:08:05.333",
      "end": "00:08:06.366"
    },
    {
      "text": "週末的那一頓重要的晚飯呢",
      "start": "00:08:06.366",
      "end": "00:08:08.500"
    },
    {
      "text": "作為週末最重要的一餐",
      "start": "00:08:08.500",
      "end": "00:08:10.166"
    },
    {
      "text": "我平時都會花很多的時間研究",
      "start": "00:08:10.166",
      "end": "00:08:12.166"
    },
    {
      "text": "這次就交給 AI 了",
      "start": "00:08:12.166",
      "end": "00:08:13.466"
    },
    {
      "text": "只要好吃",
      "start": "00:08:13.466",
      "end": "00:08:14.333"
    },
    {
      "text": "好吃好吃",
      "start": "00:08:14.333",
      "end": "00:08:15.700"
    },
    {
      "text": "就是這家",
      "start": "00:08:16.433",
      "end": "00:08:17.566"
    },
    {
      "text": "還可以",
      "start": "00:08:18.200",
      "end": "00:08:19.000"
    },
    {
      "text": "但是感受有點微妙",
      "start": "00:08:19.266",
      "end": "00:08:21.200"
    },
    {
      "text": "工作日隨便吃點啥就算了",
      "start": "00:08:21.200",
      "end": "00:08:23.000"
    },
    {
      "text": "週末的正餐也交給 AI",
      "start": "00:08:23.000",
      "end": "00:08:24.866"
    },
    {
      "text": "真的會少好多期待",
      "start": "00:08:24.866",
      "end": "00:08:26.966"
    },
    {
      "text": "快樂",
      "start": "00:08:26.966",
      "end": "00:08:27.800"
    },
    {
      "text": "可以說是沒有的",
      "start": "00:08:28.033",
      "end": "00:08:29.166"
    },
    {
      "text": "很明顯",
      "start": "00:08:29.433",
      "end": "00:08:30.166"
    },
    {
      "text": "我",
      "start": "00:08:30.166",
      "end": "00:08:30.633"
    },
    {
      "text": "差不多也腐化了",
      "start": "00:08:30.633",
      "end": "00:08:32.466"
    },
    {
      "text": "上周提交給甲方的大綱也有了回饋",
      "start": "00:08:38.200",
      "end": "00:08:40.833"
    },
    {
      "text": "HR 也送來了候選人的選題提報表",
      "start": "00:08:40.833",
      "end": "00:08:43.600"
    },
    {
      "text": "是的",
      "start": "00:08:45.066",
      "end": "00:08:45.766"
    },
    {
      "text": "甲方給的回饋",
      "start": "00:08:45.766",
      "end": "00:08:46.866"
    },
    {
      "text": "也是用 AI 寫的",
      "start": "00:08:46.866",
      "end": "00:08:48.066"
    },
    {
      "text": "比甲方用 AI 更可怕的",
      "start": "00:08:48.066",
      "end": "00:08:50.066"
    },
    {
      "text": "是應聘者",
      "start": "00:08:50.066",
      "end": "00:08:51.066"
    },
    {
      "text": "也用 AI",
      "start": "00:08:51.066",
      "end": "00:08:51.833"
    },
    {
      "text": "之所以會發現",
      "start": "00:08:51.833",
      "end": "00:08:52.833"
    },
    {
      "text": "是因為除了一眼就識破的 AI 味兒",
      "start": "00:08:52.833",
      "end": "00:08:55.000"
    },
    {
      "text": "裏面還有這麼一句話",
      "start": "00:08:55.000",
      "end": "00:08:56.500"
    },
    {
      "text": "如果我沒有猜錯",
      "start": "00:09:02.166",
      "end": "00:09:03.433"
    },
    {
      "text": "閣下是 DeepSeek 吧",
      "start": "00:09:03.433",
      "end": "00:09:05.166"
    },
    {
      "text": "24 年是它訓練截止的時間",
      "start": "00:09:05.166",
      "end": "00:09:07.333"
    },
    {
      "text": "總之最後的兩天我照常繼續刷 AI 漫劇",
      "start": "00:09:07.333",
      "end": "00:09:10.400"
    },
    {
      "text": "啥問題都找 AI",
      "start": "00:09:10.400",
      "end": "00:09:11.266"
    },
    {
      "text": "為什麼人類還沒有進化出適合久坐",
      "start": "00:09:11.266",
      "end": "00:09:14.166"
    },
    {
      "text": "Homo sapiens 大約在 30 萬年前出現",
      "start": "00:09:14.166",
      "end": "00:09:17.466"
    },
    {
      "text": "快速撐住我的腰",
      "start": "00:09:17.466",
      "end": "00:09:18.033"
    },
    {
      "text": "還用 Claude 寫 Prompt",
      "start": "00:09:18.033",
      "end": "00:09:19.333"
    },
    {
      "text": "Vibe coding 做了一個快捷鍵錄入介面的 demo",
      "start": "00:09:19.333",
      "end": "00:09:22.333"
    },
    {
      "text": "到最後我發現",
      "start": "00:09:22.333",
      "end": "00:09:23.233"
    },
    {
      "text": "我變得很不願意去思考",
      "start": "00:09:23.233",
      "end": "00:09:25.433"
    },
    {
      "text": "只要不是簡單到是我已經知道的事情",
      "start": "00:09:25.433",
      "end": "00:09:27.900"
    },
    {
      "text": "啊我都不願意去接受",
      "start": "00:09:27.900",
      "end": "00:09:29.466"
    },
    {
      "text": "從一開始我會主動想",
      "start": "00:09:29.466",
      "end": "00:09:31.066"
    },
    {
      "text": "哎那我這個問題可以用 AI",
      "start": "00:09:31.066",
      "end": "00:09:32.800"
    },
    {
      "text": "變成了我沒有思考過這個問題",
      "start": "00:09:32.800",
      "end": "00:09:34.966"
    },
    {
      "text": "我也不想思考",
      "start": "00:09:35.000",
      "end": "00:09:36.333"
    },
    {
      "text": "別問我",
      "start": "00:09:36.333",
      "end": "00:09:37.133"
    },
    {
      "text": "問 AI",
      "start": "00:09:37.233",
      "end": "00:09:38.033"
    },
    {
      "text": "所以 7 天之後",
      "start": "00:09:39.433",
      "end": "00:09:41.066"
    },
    {
      "text": "我的大腦和智力發生變化了嗎",
      "start": "00:09:41.066",
      "end": "00:09:43.833"
    },
    {
      "text": "我叫上攝像同學",
      "start": "00:09:43.833",
      "end": "00:09:45.066"
    },
    {
      "text": "再次驅車前往全景醫學影像中心",
      "start": "00:09:45.066",
      "end": "00:09:47.966"
    },
    {
      "text": "我居然記錯日期了",
      "start": "00:09:49.800",
      "end": "00:09:52.000"
    },
    {
      "text": "真是前所未有啊",
      "start": "00:09:52.000",
      "end": "00:09:53.366"
    },
    {
      "text": "我的腦子好像真的瓦特了",
      "start": "00:09:53.366",
      "end": "00:09:55.766"
    },
    {
      "text": "再次上機做了 MR 檢查後",
      "start": "00:09:57.233",
      "end": "00:09:59.366"
    },
    {
      "text": "院長告訴我",
      "start": "00:09:59.366",
      "end": "00:10:00.400"
    },
    {
      "text": "這一次就有點區別了",
      "start": "00:10:00.400",
      "end": "00:10:02.100"
    },
    {
      "text": "看到的圖片呢",
      "start": "00:10:02.233",
      "end": "00:10:03.000"
    },
    {
      "text": "就是啟動區域比較少",
      "start": "00:10:03.000",
      "end": "00:10:04.466"
    },
    {
      "text": "僅僅看到就是在左側的這個",
      "start": "00:10:04.566",
      "end": "00:10:07.166"
    },
    {
      "text": "顳葉這個區域有一點點啟動",
      "start": "00:10:07.266",
      "end": "00:10:09.733"
    },
    {
      "text": "如果看全腦整體啟動量",
      "start": "00:10:09.733",
      "end": "00:10:11.533"
    },
    {
      "text": "從 7 天前的 44000 多個像素",
      "start": "00:10:11.533",
      "end": "00:10:13.466"
    },
    {
      "text": "變成了 20000 多個像素",
      "start": "00:10:13.466",
      "end": "00:10:15.166"
    },
    {
      "text": "降低了 1/2",
      "start": "00:10:15.166",
      "end": "00:10:16.400"
    },
    {
      "text": "大腦整體更不活躍了",
      "start": "00:10:16.466",
      "end": "00:10:18.466"
    },
    {
      "text": "像是進入一種精神渙散",
      "start": "00:10:18.466",
      "end": "00:10:20.233"
    },
    {
      "text": "沒在認真做任務的懈怠狀態",
      "start": "00:10:20.233",
      "end": "00:10:22.566"
    },
    {
      "text": "其實我自己也感覺到了一些異樣",
      "start": "00:10:22.566",
      "end": "00:10:24.766"
    },
    {
      "text": "因為這個測試",
      "start": "00:10:24.766",
      "end": "00:10:25.600"
    },
    {
      "text": "會需要我全程保持大腦一片空白",
      "start": "00:10:25.600",
      "end": "00:10:28.366"
    },
    {
      "text": "只需接受眼前的刺激",
      "start": "00:10:28.366",
      "end": "00:10:30.033"
    },
    {
      "text": "7 天前的我",
      "start": "00:10:30.033",
      "end": "00:10:30.866"
    },
    {
      "text": "不管看什麼",
      "start": "00:10:30.866",
      "end": "00:10:31.733"
    },
    {
      "text": "我都很容易產生各種聯想",
      "start": "00:10:31.733",
      "end": "00:10:33.600"
    },
    {
      "text": "保持什麼都不想",
      "start": "00:10:33.600",
      "end": "00:10:35.000"
    },
    {
      "text": "對我來說",
      "start": "00:10:35.000",
      "end": "00:10:35.600"
    },
    {
      "text": "就像拉住一匹野馬一樣困難",
      "start": "00:10:35.600",
      "end": "00:10:37.600"
    },
    {
      "text": "而 7 天後",
      "start": "00:10:37.600",
      "end": "00:10:38.700"
    },
    {
      "text": "我根本就",
      "start": "00:10:40.333",
      "end": "00:10:41.266"
    },
    {
      "text": "不想去想",
      "start": "00:10:41.333",
      "end": "00:10:42.333"
    },
    {
      "text": "更有意思的是",
      "start": "00:10:42.433",
      "end": "00:10:43.366"
    },
    {
      "text": "第一次主要是枕葉視覺區被大量啟動",
      "start": "00:10:43.366",
      "end": "00:10:46.333"
    },
    {
      "text": "而現在視覺區啟動減少",
      "start": "00:10:46.333",
      "end": "00:10:48.633"
    },
    {
      "text": "同時在中央溝周圍和額葉區域",
      "start": "00:10:48.633",
      "end": "00:10:50.800"
    },
    {
      "text": "出現了新啟動",
      "start": "00:10:50.800",
      "end": "00:10:51.833"
    },
    {
      "text": "前額葉倒是活躍起來了",
      "start": "00:10:51.833",
      "end": "00:10:53.800"
    },
    {
      "text": "這說明",
      "start": "00:10:53.800",
      "end": "00:10:54.266"
    },
    {
      "text": "原本只靠看",
      "start": "00:10:54.266",
      "end": "00:10:55.133"
    },
    {
      "text": "我就可以完成的簡單任務",
      "start": "00:10:55.133",
      "end": "00:10:56.666"
    },
    {
      "text": "現在由於大腦整體不活躍",
      "start": "00:10:56.666",
      "end": "00:10:58.433"
    },
    {
      "text": "就只能夠派出前額葉來加班完成了",
      "start": "00:10:58.433",
      "end": "00:11:01.133"
    },
    {
      "text": "結構上不會有太大的變化",
      "start": "00:11:01.133",
      "end": "00:11:03.566"
    },
    {
      "text": "基本上啊",
      "start": "00:11:03.566",
      "end": "00:11:04.233"
    },
    {
      "text": "它是功能性的",
      "start": "00:11:04.233",
      "end": "00:11:05.466"
    },
    {
      "text": "沒有病理上的損傷",
      "start": "00:11:05.633",
      "end": "00:11:07.433"
    },
    {
      "text": "但在功能表現上",
      "start": "00:11:07.433",
      "end": "00:11:08.600"
    },
    {
      "text": "出現了全局退縮",
      "start": "00:11:08.600",
      "end": "00:11:10.200"
    },
    {
      "text": "前額葉補償的現象",
      "start": "00:11:10.200",
      "end": "00:11:11.733"
    },
    {
      "text": "大腦呢",
      "start": "00:11:11.733",
      "end": "00:11:12.366"
    },
    {
      "text": "它這個海馬體是相當於一個硬碟",
      "start": "00:11:12.366",
      "end": "00:11:15.566"
    },
    {
      "text": "它可以儲存長期的記憶",
      "start": "00:11:15.566",
      "end": "00:11:17.166"
    },
    {
      "text": "額葉呢它可以做一個臨時的儲存",
      "start": "00:11:17.166",
      "end": "00:11:19.733"
    },
    {
      "text": "相當於電腦的這個記憶體一樣",
      "start": "00:11:19.733",
      "end": "00:11:21.600"
    },
    {
      "text": "這就是 AI 代替我思考 7 天之後",
      "start": "00:11:21.733",
      "end": "00:11:24.433"
    },
    {
      "text": "大腦發生的變化",
      "start": "00:11:24.433",
      "end": "00:11:26.100"
    },
    {
      "text": "至於智力",
      "start": "00:11:26.133",
      "end": "00:11:27.466"
    },
    {
      "text": "錯了兩個",
      "start": "00:11:27.466",
      "end": "00:11:28.033"
    },
    {
      "text": "多錯一道",
      "start": "00:11:28.033",
      "end": "00:11:29.166"
    },
    {
      "text": "多錯了一道",
      "start": "00:11:29.466",
      "end": "00:11:30.800"
    },
    {
      "text": "多錯了一道題",
      "start": "00:11:31.566",
      "end": "00:11:32.400"
    },
    {
      "text": "問題不大",
      "start": "00:11:32.400",
      "end": "00:11:33.133"
    },
    {
      "text": "但卻多花了十幾分鐘",
      "start": "00:11:33.133",
      "end": "00:11:35.766"
    },
    {
      "text": "結果很明朗了",
      "start": "00:11:35.766",
      "end": "00:11:37.233"
    },
    {
      "text": "生理上不太會真的變笨",
      "start": "00:11:37.233",
      "end": "00:11:39.666"
    },
    {
      "text": "但我確實看起來功能減退",
      "start": "00:11:39.666",
      "end": "00:11:42.133"
    },
    {
      "text": "表現的不好了",
      "start": "00:11:42.133",
      "end": "00:11:43.266"
    },
    {
      "text": "那具體來說",
      "start": "00:11:43.266",
      "end": "00:11:44.200"
    },
    {
      "text": "是什麼能力變弱了呢",
      "start": "00:11:44.200",
      "end": "00:11:46.066"
    },
    {
      "text": "其實實驗前後",
      "start": "00:11:46.066",
      "end": "00:11:46.933"
    },
    {
      "text": "我還做了幾個別的測試",
      "start": "00:11:46.933",
      "end": "00:11:48.566"
    },
    {
      "text": "發現自控力沒有變差",
      "start": "00:11:48.566",
      "end": "00:11:50.933"
    },
    {
      "text": "太好了",
      "start": "00:11:50.933",
      "end": "00:11:51.733"
    },
    {
      "text": "批判性思維沒有變差",
      "start": "00:11:51.733",
      "end": "00:11:53.633"
    },
    {
      "text": "太好了",
      "start": "00:11:53.633",
      "end": "00:11:54.433"
    },
    {
      "text": "注意力啊",
      "start": "00:11:54.433",
      "end": "00:11:55.733"
    },
    {
      "text": "眼動儀顯示",
      "start": "00:11:55.766",
      "end": "00:11:56.766"
    },
    {
      "text": "跟第一次比",
      "start": "00:11:56.766",
      "end": "00:11:57.600"
    },
    {
      "text": "我的瞳孔收縮",
      "start": "00:11:57.600",
      "end": "00:11:58.633"
    },
    {
      "text": "目光四處遊走",
      "start": "00:11:58.633",
      "end": "00:11:59.666"
    },
    {
      "text": "而且很快就疲勞了",
      "start": "00:11:59.666",
      "end": "00:12:00.933"
    },
    {
      "text": "注意力明顯變差",
      "start": "00:12:00.933",
      "end": "00:12:02.466"
    },
    {
      "text": "認知耐力顯著下降",
      "start": "00:12:03.233",
      "end": "00:12:05.766"
    },
    {
      "text": "不只是閱讀題",
      "start": "00:12:05.766",
      "end": "00:12:07.000"
    },
    {
      "text": "在做智力考試時",
      "start": "00:12:07.000",
      "end": "00:12:08.066"
    },
    {
      "text": "我的身體也一直不自覺的湊向螢幕",
      "start": "00:12:08.066",
      "end": "00:12:10.533"
    },
    {
      "text": "到後面真的很難集中注意力",
      "start": "00:12:10.566",
      "end": "00:12:12.400"
    },
    {
      "text": "很不耐煩",
      "start": "00:12:12.400",
      "end": "00:12:13.466"
    },
    {
      "text": "表現最差的是工作記憶",
      "start": "00:12:14.200",
      "end": "00:12:16.066"
    },
    {
      "text": "至少對我來說是毀滅性的降低",
      "start": "00:12:16.066",
      "end": "00:12:18.600"
    },
    {
      "text": "在這個需要同時記住眼前看到的",
      "start": "00:12:18.600",
      "end": "00:12:20.633"
    },
    {
      "text": "和耳朵裏聽到的東西的高難度測試裏",
      "start": "00:12:20.633",
      "end": "00:12:23.166"
    },
    {
      "text": "我之前的表現算是還不錯",
      "start": "00:12:23.166",
      "end": "00:12:25.466"
    },
    {
      "text": "但現在",
      "start": "00:12:25.466",
      "end": "00:12:26.233"
    },
    {
      "text": "我真的完全記不清",
      "start": "00:12:26.233",
      "end": "00:12:27.466"
    },
    {
      "text": "手忙腳亂的",
      "start": "00:12:27.466",
      "end": "00:12:28.400"
    },
    {
      "text": "很痛苦",
      "start": "00:12:28.400",
      "end": "00:12:29.466"
    },
    {
      "text": "現在我們很流行說自己",
      "start": "00:12:35.200",
      "end": "00:12:36.533"
    },
    {
      "text": "“前額葉不好”",
      "start": "00:12:36.533",
      "end": "00:12:37.566"
    },
    {
      "text": "這個不好比起病理上的真損傷",
      "start": "00:12:37.566",
      "end": "00:12:39.966"
    },
    {
      "text": "倒是更貼近",
      "start": "00:12:39.966",
      "end": "00:12:40.733"
    },
    {
      "text": "我們視頻裏展現出來這種",
      "start": "00:12:40.733",
      "end": "00:12:42.366"
    },
    {
      "text": "功能衰退",
      "start": "00:12:42.366",
      "end": "00:12:43.400"
    },
    {
      "text": "所以就算你發現自己特別依賴 AI",
      "start": "00:12:43.400",
      "end": "00:12:46.333"
    },
    {
      "text": "也不用太害怕",
      "start": "00:12:46.333",
      "end": "00:12:47.800"
    },
    {
      "text": "它不是病",
      "start": "00:12:47.800",
      "end": "00:12:48.733"
    },
    {
      "text": "而且挽回也完全來得及",
      "start": "00:12:48.733",
      "end": "00:12:50.766"
    },
    {
      "text": "但是才 7 天",
      "start": "00:12:50.766",
      "end": "00:12:51.666"
    },
    {
      "text": "就衰退了",
      "start": "00:12:51.666",
      "end": "00:12:52.433"
    },
    {
      "text": "連院長也在採訪的時候",
      "start": "00:12:52.433",
      "end": "00:12:53.833"
    },
    {
      "text": "開玩笑說了兩次",
      "start": "00:12:53.833",
      "end": "00:12:55.166"
    },
    {
      "text": "自己前額葉也不太好",
      "start": "00:12:55.166",
      "end": "00:12:56.933"
    },
    {
      "text": "就是一種情景記憶的這個減退",
      "start": "00:12:56.933",
      "end": "00:13:00.133"
    },
    {
      "text": "還有推演分析能力的減退",
      "start": "00:13:00.266",
      "end": "00:13:02.466"
    },
    {
      "text": "另外就是自己對自己的認識",
      "start": "00:13:02.466",
      "end": "00:13:04.800"
    },
    {
      "text": "也會減退",
      "start": "00:13:04.800",
      "end": "00:13:05.766"
    },
    {
      "text": "哈佛大學的最新評論也有提到",
      "start": "00:13:05.833",
      "end": "00:13:07.666"
    },
    {
      "text": "如果把思考本身外包出去",
      "start": "00:13:07.666",
      "end": "00:13:09.733"
    },
    {
      "text": "發生認知卸載",
      "start": "00:13:09.733",
      "end": "00:13:11.033"
    },
    {
      "text": "人類的認知就有退化的風險",
      "start": "00:13:11.033",
      "end": "00:13:12.966"
    },
    {
      "text": "有個說法叫",
      "start": "00:13:12.966",
      "end": "00:13:14.000"
    },
    {
      "text": "這個用在腦子上",
      "start": "00:13:15.633",
      "end": "00:13:16.766"
    },
    {
      "text": "果然也是成立的呀",
      "start": "00:13:16.766",
      "end": "00:13:18.666"
    },
    {
      "text": "哎我是不是應該順勢賣一點",
      "start": "00:13:19.266",
      "end": "00:13:21.633"
    },
    {
      "text": "挽救前額葉",
      "start": "00:13:21.633",
      "end": "00:13:23.033"
    },
    {
      "text": "拯救腦腐的課程",
      "start": "00:13:23.033",
      "end": "00:13:25.633"
    },
    {
      "text": "不過以我的經驗來說",
      "start": "00:13:25.633",
      "end": "00:13:27.200"
    },
    {
      "text": "多呼吸新鮮空氣",
      "start": "00:13:27.200",
      "end": "00:13:28.766"
    },
    {
      "text": "呃多去做一些主動思考",
      "start": "00:13:28.766",
      "end": "00:13:30.933"
    },
    {
      "text": "多去消費一些比較延遲滿足的長內容",
      "start": "00:13:31.733",
      "end": "00:13:35.733"
    },
    {
      "text": "應該就沒問題",
      "start": "00:13:35.733",
      "end": "00:13:37.400"
    }
  ]
}
