{
  "schema": "tsumugu/transcript-cues@1",
  "lang": "zh-Hant",
  "source": "transcript:iphone-18-lineup-preview.zh-Hant.vtt",
  "videoId": "4Lhkx1wnEDE",
  "cues": [
    {
      "text": "今年 iPhone 要出折疊屏了",
      "start": "00:00:00.000",
      "end": "00:00:02.791"
    },
    {
      "text": "這就是非常接近真機的機模",
      "start": "00:00:02.791",
      "end": "00:00:05.500"
    },
    {
      "text": "它的存在",
      "start": "00:00:05.500",
      "end": "00:00:06.250"
    },
    {
      "text": "很久以前就不是什麼秘密",
      "start": "00:00:06.250",
      "end": "00:00:08.000"
    },
    {
      "text": "甚至有朋友還因為它",
      "start": "00:00:08.000",
      "end": "00:00:09.458"
    },
    {
      "text": "跳過了去年的 iPhone 17 系列",
      "start": "00:00:09.458",
      "end": "00:00:11.666"
    },
    {
      "text": "正在持幣觀望中",
      "start": "00:00:11.666",
      "end": "00:00:13.416"
    },
    {
      "text": "嗯非常明智",
      "start": "00:00:13.416",
      "end": "00:00:15.083"
    },
    {
      "text": "如果我們還停留在 2023 年的話",
      "start": "00:00:15.083",
      "end": "00:00:17.625"
    },
    {
      "text": "但我們是處在一切都在瘋狂漲價的",
      "start": "00:00:17.625",
      "end": "00:00:20.416"
    },
    {
      "text": "混亂的 2026 年",
      "start": "00:00:20.416",
      "end": "00:00:22.208"
    },
    {
      "text": "今年的情況還特殊的",
      "start": "00:00:22.208",
      "end": "00:00:23.958"
    },
    {
      "text": "還有不到 4 個月就要上市",
      "start": "00:00:23.958",
      "end": "00:00:25.333"
    },
    {
      "text": "除了外形確定長這樣",
      "start": "00:00:25.333",
      "end": "00:00:26.833"
    },
    {
      "text": "其他功能特性",
      "start": "00:00:26.833",
      "end": "00:00:27.666"
    },
    {
      "text": "因為很多的曝光",
      "start": "00:00:27.666",
      "end": "00:00:28.750"
    },
    {
      "text": "基本上也已經塵埃落定",
      "start": "00:00:28.750",
      "end": "00:00:30.583"
    },
    {
      "text": "所以今天這期視頻",
      "start": "00:00:30.583",
      "end": "00:00:31.875"
    },
    {
      "text": "我們就來一起瞭解一下",
      "start": "00:00:31.875",
      "end": "00:00:33.375"
    },
    {
      "text": "今年即將推出的 iPhone 們",
      "start": "00:00:33.375",
      "end": "00:00:35.458"
    },
    {
      "text": "你所需要知道的一切",
      "start": "00:00:35.458",
      "end": "00:00:36.875"
    },
    {
      "text": "我估計",
      "start": "00:00:36.875",
      "end": "00:00:37.416"
    },
    {
      "text": "你們當中的有些人",
      "start": "00:00:37.416",
      "end": "00:00:38.416"
    },
    {
      "text": "已經不用再持幣等待",
      "start": "00:00:38.416",
      "end": "00:00:40.625"
    },
    {
      "text": "首先 iPhone 18",
      "start": "00:00:41.083",
      "end": "00:00:42.916"
    },
    {
      "text": "今年最大的變故就是",
      "start": "00:00:48.000",
      "end": "00:00:49.833"
    },
    {
      "text": "沒有標準版 iPhone 18",
      "start": "00:00:49.833",
      "end": "00:00:52.291"
    },
    {
      "text": "蘋果前所未有的",
      "start": "00:00:52.291",
      "end": "00:00:53.875"
    },
    {
      "text": "把 iPhone 的發佈",
      "start": "00:00:53.875",
      "end": "00:00:55.000"
    },
    {
      "text": "分成了兩輪",
      "start": "00:00:55.000",
      "end": "00:00:56.166"
    },
    {
      "text": "今年只會發佈 Pro 系列",
      "start": "00:00:56.166",
      "end": "00:00:57.791"
    },
    {
      "text": "和折疊屏 iPhone Ultra",
      "start": "00:00:57.791",
      "end": "00:00:59.333"
    },
    {
      "text": "都很貴",
      "start": "00:00:59.333",
      "end": "00:01:00.083"
    },
    {
      "text": "普通版 iPhone 18 系列",
      "start": "00:01:00.083",
      "end": "00:01:01.333"
    },
    {
      "text": "會延後到 2027 年春天",
      "start": "00:01:01.333",
      "end": "00:01:03.458"
    },
    {
      "text": "而且新的普通版 iPhone 18 系列和 17 比",
      "start": "00:01:03.458",
      "end": "00:01:06.333"
    },
    {
      "text": "也沒有很大變化",
      "start": "00:01:06.333",
      "end": "00:01:07.666"
    },
    {
      "text": "外觀和功能都沒有新增",
      "start": "00:01:07.666",
      "end": "00:01:09.416"
    },
    {
      "text": "唯二的變化",
      "start": "00:01:09.416",
      "end": "00:01:10.291"
    },
    {
      "text": "是前置攝像頭的像素數",
      "start": "00:01:10.291",
      "end": "00:01:12.166"
    },
    {
      "text": "從 1800 萬升級到了 2400 萬",
      "start": "00:01:12.166",
      "end": "00:01:14.958"
    },
    {
      "text": "以及晶片",
      "start": "00:01:14.958",
      "end": "00:01:15.625"
    },
    {
      "text": "換成了 A20",
      "start": "00:01:15.625",
      "end": "00:01:16.541"
    },
    {
      "text": "2 納米制程",
      "start": "00:01:16.666",
      "end": "00:01:17.666"
    },
    {
      "text": "這意味著性能和能效",
      "start": "00:01:17.666",
      "end": "00:01:19.166"
    },
    {
      "text": "都有不小的提升",
      "start": "00:01:19.166",
      "end": "00:01:20.291"
    },
    {
      "text": "而且記憶體從 8 GB 上升到了 12 GB",
      "start": "00:01:20.291",
      "end": "00:01:23.208"
    },
    {
      "text": "iPhone 18 延後的主要原因",
      "start": "00:01:23.208",
      "end": "00:01:25.166"
    },
    {
      "text": "應該是要讓供應鏈盡可能的把產能貢獻給",
      "start": "00:01:25.166",
      "end": "00:01:28.041"
    },
    {
      "text": "iPhone 18 Pro 和 iPhone Ultra",
      "start": "00:01:28.041",
      "end": "00:01:29.166"
    },
    {
      "text": "因為它們的新零件更多",
      "start": "00:01:29.166",
      "end": "00:01:30.833"
    },
    {
      "text": "生產難度更高",
      "start": "00:01:30.833",
      "end": "00:01:32.166"
    },
    {
      "text": "總之如果你原計畫是要買 iPhone 18 的話",
      "start": "00:01:32.166",
      "end": "00:01:34.333"
    },
    {
      "text": "那還不如你早點買打折的 iPhone 17",
      "start": "00:01:34.333",
      "end": "00:01:37.125"
    },
    {
      "text": "比較划算",
      "start": "00:01:37.125",
      "end": "00:01:37.958"
    },
    {
      "text": "然後就是 2026 年最重磅的發佈",
      "start": "00:01:44.666",
      "end": "00:01:47.791"
    },
    {
      "text": "iPhone 的首個折疊屏",
      "start": "00:01:47.791",
      "end": "00:01:49.791"
    },
    {
      "text": "iPhone Ultra",
      "start": "00:01:49.791",
      "end": "00:01:51.000"
    },
    {
      "text": "這個手機",
      "start": "00:01:52.041",
      "end": "00:01:52.833"
    },
    {
      "text": "也太備受期待了",
      "start": "00:01:52.833",
      "end": "00:01:54.416"
    },
    {
      "text": "很多人會覺得",
      "start": "00:01:54.416",
      "end": "00:01:55.541"
    },
    {
      "text": "它的出現就可以重新定義折疊手機",
      "start": "00:01:55.541",
      "end": "00:01:58.666"
    },
    {
      "text": "把折疊屏帶向主流",
      "start": "00:01:58.666",
      "end": "00:02:00.416"
    },
    {
      "text": "畢竟蘋果一直以來都是這樣做的",
      "start": "00:02:00.416",
      "end": "00:02:02.416"
    },
    {
      "text": "不求最早",
      "start": "00:02:02.416",
      "end": "00:02:03.375"
    },
    {
      "text": "只求最好",
      "start": "00:02:03.375",
      "end": "00:02:04.333"
    },
    {
      "text": "但是在瞭解這個手機如何如何革命",
      "start": "00:02:04.333",
      "end": "00:02:06.791"
    },
    {
      "text": "能他人所不能之前",
      "start": "00:02:06.791",
      "end": "00:02:08.333"
    },
    {
      "text": "我覺得需要讓大家先知道",
      "start": "00:02:08.333",
      "end": "00:02:10.250"
    },
    {
      "text": "它的價格",
      "start": "00:02:10.250",
      "end": "00:02:11.375"
    },
    {
      "text": "18000 元",
      "start": "00:02:19.833",
      "end": "00:02:21.541"
    },
    {
      "text": "基本上所有的洩露都指向",
      "start": "00:02:21.541",
      "end": "00:02:23.666"
    },
    {
      "text": "iPhone Ultra 256GB",
      "start": "00:02:23.666",
      "end": "00:02:25.333"
    },
    {
      "text": "最低配會賣到 2000 美元以上",
      "start": "00:02:25.333",
      "end": "00:02:27.750"
    },
    {
      "text": "很高概率是 2300 美元",
      "start": "00:02:27.750",
      "end": "00:02:30.625"
    },
    {
      "text": "換算成國行的話是 18500",
      "start": "00:02:30.625",
      "end": "00:02:33.791"
    },
    {
      "text": "18000 是什麼概念",
      "start": "00:02:33.833",
      "end": "00:02:35.291"
    },
    {
      "text": "18000 可以買一個 LV 了",
      "start": "00:02:35.291",
      "end": "00:02:37.791"
    },
    {
      "text": "18000 還能買到",
      "start": "00:02:37.958",
      "end": "00:02:39.958"
    },
    {
      "text": "師傅",
      "start": "00:02:42.958",
      "end": "00:02:43.750"
    },
    {
      "text": "你這一車蘋果多少錢啊",
      "start": "00:02:44.291",
      "end": "00:02:46.166"
    },
    {
      "text": "一萬八",
      "start": "00:02:46.500",
      "end": "00:02:47.250"
    },
    {
      "text": "最近幾年的 iPhone",
      "start": "00:02:47.250",
      "end": "00:02:48.250"
    },
    {
      "text": "稍微有一點",
      "start": "00:02:48.250",
      "end": "00:02:49.000"
    },
    {
      "text": "一分價錢一分貨的感覺了",
      "start": "00:02:49.000",
      "end": "00:02:51.000"
    },
    {
      "text": "搞得我都快忘了",
      "start": "00:02:51.000",
      "end": "00:02:52.083"
    },
    {
      "text": "以前它可是有“腎”的名聲的",
      "start": "00:02:52.083",
      "end": "00:02:54.375"
    },
    {
      "text": "現在",
      "start": "00:02:54.375",
      "end": "00:02:55.000"
    },
    {
      "text": "這個超有辨識度",
      "start": "00:02:55.000",
      "end": "00:02:56.250"
    },
    {
      "text": "裝逼效果最強的“i 腎”",
      "start": "00:02:56.250",
      "end": "00:02:58.583"
    },
    {
      "text": "它回歸了",
      "start": "00:02:58.583",
      "end": "00:02:59.583"
    },
    {
      "text": "它重回了輕奢地位",
      "start": "00:02:59.583",
      "end": "00:03:01.458"
    },
    {
      "text": "我都能想到 iPhone Ultra 發佈當天",
      "start": "00:03:01.458",
      "end": "00:03:03.666"
    },
    {
      "text": "各大平臺各種關於價格的熱搜",
      "start": "00:03:03.666",
      "end": "00:03:06.333"
    },
    {
      "text": "各種議論肯定要吵上天",
      "start": "00:03:06.333",
      "end": "00:03:08.625"
    },
    {
      "text": "好了",
      "start": "00:03:08.625",
      "end": "00:03:09.000"
    },
    {
      "text": "那現在大家把這個定價裝在心裏",
      "start": "00:03:09.000",
      "end": "00:03:11.166"
    },
    {
      "text": "我們一起來看一看",
      "start": "00:03:11.166",
      "end": "00:03:12.166"
    },
    {
      "text": "這個 iPhone Ultra",
      "start": "00:03:12.166",
      "end": "00:03:13.666"
    },
    {
      "text": "到底和別的折疊有什麼不同",
      "start": "00:03:13.666",
      "end": "00:03:15.833"
    },
    {
      "text": "目前市面上的折疊",
      "start": "00:03:16.500",
      "end": "00:03:17.625"
    },
    {
      "text": "大概就會有三種",
      "start": "00:03:17.625",
      "end": "00:03:18.958"
    },
    {
      "text": "大折疊 小折疊 和三折疊",
      "start": "00:03:18.958",
      "end": "00:03:21.041"
    },
    {
      "text": "小折疊相當於把普通手機對折",
      "start": "00:03:21.041",
      "end": "00:03:23.583"
    },
    {
      "text": "功能弱",
      "start": "00:03:23.583",
      "end": "00:03:24.250"
    },
    {
      "text": "續航低",
      "start": "00:03:24.250",
      "end": "00:03:24.875"
    },
    {
      "text": "“美麗的小廢物”",
      "start": "00:03:24.875",
      "end": "00:03:26.250"
    },
    {
      "text": "大折疊外屏是普通手機",
      "start": "00:03:26.250",
      "end": "00:03:28.833"
    },
    {
      "text": "翻開以後變成正方形",
      "start": "00:03:28.833",
      "end": "00:03:30.583"
    },
    {
      "text": "大屏確實是大屏",
      "start": "00:03:30.583",
      "end": "00:03:32.041"
    },
    {
      "text": "看文檔網頁視野很好",
      "start": "00:03:32.041",
      "end": "00:03:34.000"
    },
    {
      "text": "但是看視頻",
      "start": "00:03:34.000",
      "end": "00:03:34.958"
    },
    {
      "text": "黑邊太多",
      "start": "00:03:35.000",
      "end": "00:03:35.958"
    },
    {
      "text": "實際顯示面積和普通手機差不太多",
      "start": "00:03:35.958",
      "end": "00:03:38.833"
    },
    {
      "text": "三折疊",
      "start": "00:03:38.833",
      "end": "00:03:39.833"
    },
    {
      "text": "翻開以後",
      "start": "00:03:39.833",
      "end": "00:03:40.625"
    },
    {
      "text": "比例面積",
      "start": "00:03:40.625",
      "end": "00:03:41.375"
    },
    {
      "text": "都相當於是 10 英寸的平板",
      "start": "00:03:41.375",
      "end": "00:03:43.250"
    },
    {
      "text": "最有用",
      "start": "00:03:43.250",
      "end": "00:03:43.875"
    },
    {
      "text": "但也最貴",
      "start": "00:03:43.875",
      "end": "00:03:44.625"
    },
    {
      "text": "而且折疊起來的狀態很厚",
      "start": "00:03:44.625",
      "end": "00:03:46.750"
    },
    {
      "text": "折痕也很明顯",
      "start": "00:03:46.750",
      "end": "00:03:48.000"
    },
    {
      "text": "也就是說無論你能夠付出多少錢",
      "start": "00:03:48.000",
      "end": "00:03:50.666"
    },
    {
      "text": "你目前都買不到一個",
      "start": "00:03:50.666",
      "end": "00:03:52.166"
    },
    {
      "text": "所謂完美的折疊屏手機",
      "start": "00:03:52.166",
      "end": "00:03:54.000"
    },
    {
      "text": "iPhone Ultra 的話",
      "start": "00:03:54.000",
      "end": "00:03:55.000"
    },
    {
      "text": "我覺得它會是一個新物種",
      "start": "00:03:55.000",
      "end": "00:03:57.000"
    },
    {
      "text": "也就是第四種",
      "start": "00:03:57.000",
      "end": "00:03:58.166"
    },
    {
      "text": "它有三個關鍵字",
      "start": "00:03:58.166",
      "end": "00:04:00.000"
    },
    {
      "text": "先說比例",
      "start": "00:04:02.083",
      "end": "00:04:03.083"
    },
    {
      "text": "iPhone Ultra 最特立獨行的地方是",
      "start": "00:04:03.083",
      "end": "00:04:05.000"
    },
    {
      "text": "它是護照式折疊",
      "start": "00:04:05.000",
      "end": "00:04:06.958"
    },
    {
      "text": "合起來像是一個小冊子",
      "start": "00:04:06.958",
      "end": "00:04:09.166"
    },
    {
      "text": "最明顯的好處",
      "start": "00:04:09.166",
      "end": "00:04:10.000"
    },
    {
      "text": "就是不論翻開看橫屏",
      "start": "00:04:10.000",
      "end": "00:04:11.500"
    },
    {
      "text": "還是在外屏刷豎屏",
      "start": "00:04:11.500",
      "end": "00:04:13.000"
    },
    {
      "text": "黑邊都能接受",
      "start": "00:04:13.000",
      "end": "00:04:14.458"
    },
    {
      "text": "比正方形沉浸得多",
      "start": "00:04:14.458",
      "end": "00:04:16.000"
    },
    {
      "text": "畢竟是口袋裏的 iPad mini 嘛",
      "start": "00:04:16.000",
      "end": "00:04:18.375"
    },
    {
      "text": "iPad mini 最擅長的",
      "start": "00:04:18.375",
      "end": "00:04:19.958"
    },
    {
      "text": "閱讀",
      "start": "00:04:19.958",
      "end": "00:04:20.583"
    },
    {
      "text": "刷視頻",
      "start": "00:04:20.583",
      "end": "00:04:21.208"
    },
    {
      "text": "看視頻",
      "start": "00:04:21.208",
      "end": "00:04:21.833"
    },
    {
      "text": "玩遊戲",
      "start": "00:04:21.833",
      "end": "00:04:22.583"
    },
    {
      "text": "打字",
      "start": "00:04:22.583",
      "end": "00:04:23.083"
    },
    {
      "text": "這些任務",
      "start": "00:04:23.083",
      "end": "00:04:23.833"
    },
    {
      "text": "iPhone Ultra 的內屏都能承接",
      "start": "00:04:23.833",
      "end": "00:04:25.958"
    },
    {
      "text": "毫無壓力",
      "start": "00:04:25.958",
      "end": "00:04:26.791"
    },
    {
      "text": "敏銳的觀眾應該已經發現",
      "start": "00:04:26.791",
      "end": "00:04:28.750"
    },
    {
      "text": "視頻的 Broll 從中間開始",
      "start": "00:04:28.750",
      "end": "00:04:30.333"
    },
    {
      "text": "就換成了一個很像是真機的東西",
      "start": "00:04:30.333",
      "end": "00:04:32.500"
    },
    {
      "text": "它其實是華為最近剛剛發佈的 Pura X Max",
      "start": "00:04:32.791",
      "end": "00:04:36.833"
    },
    {
      "text": "我買來展示的",
      "start": "00:04:36.833",
      "end": "00:04:38.000"
    },
    {
      "text": "因為它和 iPhone Ultra",
      "start": "00:04:38.000",
      "end": "00:04:39.458"
    },
    {
      "text": "尺寸 厚度 比例",
      "start": "00:04:39.458",
      "end": "00:04:41.000"
    },
    {
      "text": "幾乎一模一樣",
      "start": "00:04:41.000",
      "end": "00:04:42.458"
    },
    {
      "text": "這個萬金油比例對應的數字也很神奇",
      "start": "00:04:42.458",
      "end": "00:04:45.416"
    },
    {
      "text": "不是常見的 4:3 啊 16:10 這種",
      "start": "00:04:45.416",
      "end": "00:04:48.000"
    },
    {
      "text": "而是 √2：1",
      "start": "00:04:48.000",
      "end": "00:04:50.208"
    },
    {
      "text": "√2：1 對折之後",
      "start": "00:04:50.208",
      "end": "00:04:52.083"
    },
    {
      "text": "它的比例還是 √2：1",
      "start": "00:04:52.083",
      "end": "00:04:54.500"
    },
    {
      "text": "A4 紙就是這個比例",
      "start": "00:04:54.500",
      "end": "00:04:56.166"
    },
    {
      "text": "對折之後就變成了 A5",
      "start": "00:04:56.166",
      "end": "00:04:58.958"
    },
    {
      "text": "難道蘋果是想減輕開發者",
      "start": "00:04:59.208",
      "end": "00:05:00.875"
    },
    {
      "text": "對不同比例的優化工作量",
      "start": "00:05:00.875",
      "end": "00:05:03.208"
    },
    {
      "text": "不過",
      "start": "00:05:03.208",
      "end": "00:05:03.791"
    },
    {
      "text": "iPhone Ultra 的神奇比例也不是沒有犧牲品",
      "start": "00:05:03.791",
      "end": "00:05:06.375"
    },
    {
      "text": "就是外屏",
      "start": "00:05:06.375",
      "end": "00:05:07.500"
    },
    {
      "text": "很矮 很寬",
      "start": "00:05:07.500",
      "end": "00:05:08.750"
    },
    {
      "text": "打字很不方便",
      "start": "00:05:08.833",
      "end": "00:05:10.166"
    },
    {
      "text": "鍵盤還會遮擋一大片螢幕",
      "start": "00:05:10.166",
      "end": "00:05:12.291"
    },
    {
      "text": "咋辦",
      "start": "00:05:12.291",
      "end": "00:05:13.000"
    },
    {
      "text": "Apple Intelligence 語音輸入",
      "start": "00:05:13.000",
      "end": "00:05:15.041"
    },
    {
      "text": "然後是折痕",
      "start": "00:05:15.041",
      "end": "00:05:16.666"
    },
    {
      "text": "iPhone Ultra 第二個特立獨行的地方",
      "start": "00:05:16.666",
      "end": "00:05:19.333"
    },
    {
      "text": "雖然在機模上看不出來",
      "start": "00:05:19.333",
      "end": "00:05:21.500"
    },
    {
      "text": "但是 iPhone Ultra 的螢幕",
      "start": "00:05:21.500",
      "end": "00:05:23.666"
    },
    {
      "text": "據說是幾乎沒有折痕的",
      "start": "00:05:23.666",
      "end": "00:05:26.583"
    },
    {
      "text": "蘋果利用了液態金屬鉸鏈",
      "start": "00:05:26.583",
      "end": "00:05:28.666"
    },
    {
      "text": "和自適應 OCA 光學膠",
      "start": "00:05:28.666",
      "end": "00:05:30.750"
    },
    {
      "text": "讓 iPhone Ultra 的折痕",
      "start": "00:05:30.750",
      "end": "00:05:32.083"
    },
    {
      "text": "最終會控制在 0.15 毫米以內",
      "start": "00:05:32.083",
      "end": "00:05:35.166"
    },
    {
      "text": "這也是蘋果憋了這麼多年",
      "start": "00:05:35.166",
      "end": "00:05:36.666"
    },
    {
      "text": "沒有出折疊屏的原因",
      "start": "00:05:36.666",
      "end": "00:05:38.208"
    },
    {
      "text": "因為它肯定不想做三星的跟風者",
      "start": "00:05:38.208",
      "end": "00:05:41.041"
    },
    {
      "text": "既然要做",
      "start": "00:05:41.041",
      "end": "00:05:41.833"
    },
    {
      "text": "就要默默努力",
      "start": "00:05:41.833",
      "end": "00:05:42.833"
    },
    {
      "text": "然後突然出現驚豔所有人",
      "start": "00:05:42.833",
      "end": "00:05:45.000"
    },
    {
      "text": "我猜",
      "start": "00:05:45.000",
      "end": "00:05:45.416"
    },
    {
      "text": "效果可能會和 OPPO 今年新機差不多",
      "start": "00:05:45.416",
      "end": "00:05:47.833"
    },
    {
      "text": "實際怎麼樣只能等肉眼看真機了",
      "start": "00:05:47.833",
      "end": "00:05:50.500"
    },
    {
      "text": "很期待發佈會了",
      "start": "00:05:50.500",
      "end": "00:05:52.083"
    },
    {
      "text": "最後就是妥協",
      "start": "00:05:58.250",
      "end": "00:05:59.500"
    },
    {
      "text": "主要有三點",
      "start": "00:05:59.500",
      "end": "00:06:00.500"
    },
    {
      "text": "第一 Face ID 沒有了",
      "start": "00:06:00.500",
      "end": "00:06:02.833"
    },
    {
      "text": "雖然 iPhone Ultra 的內外屏",
      "start": "00:06:02.833",
      "end": "00:06:04.291"
    },
    {
      "text": "這裏都有一個靈動島",
      "start": "00:06:04.291",
      "end": "00:06:06.000"
    },
    {
      "text": "但是它們裏面只有攝像頭",
      "start": "00:06:06.000",
      "end": "00:06:08.291"
    },
    {
      "text": "沒有 Face ID 模組",
      "start": "00:06:08.291",
      "end": "00:06:09.833"
    },
    {
      "text": "應該是機身太薄塞不下了",
      "start": "00:06:09.833",
      "end": "00:06:12.166"
    },
    {
      "text": "取而代之的是電源鍵上的 Touch ID",
      "start": "00:06:12.166",
      "end": "00:06:15.333"
    },
    {
      "text": "不喜歡這個",
      "start": "00:06:16.166",
      "end": "00:06:17.166"
    },
    {
      "text": "不如以前 Home 鍵的 Touch ID",
      "start": "00:06:17.166",
      "end": "00:06:18.833"
    },
    {
      "text": "也遠不如 Face ID",
      "start": "00:06:18.833",
      "end": "00:06:20.666"
    },
    {
      "text": "很大的妥協",
      "start": "00:06:20.666",
      "end": "00:06:21.541"
    },
    {
      "text": "第二個 相機",
      "start": "00:06:21.541",
      "end": "00:06:23.041"
    },
    {
      "text": "只有兩個鏡頭",
      "start": "00:06:23.041",
      "end": "00:06:24.208"
    },
    {
      "text": "沒有長焦",
      "start": "00:06:24.208",
      "end": "00:06:25.250"
    },
    {
      "text": "我覺得長焦還是挺重要的",
      "start": "00:06:25.250",
      "end": "00:06:26.833"
    },
    {
      "text": "作為歷史上最貴的 iPhone",
      "start": "00:06:26.833",
      "end": "00:06:28.541"
    },
    {
      "text": "它竟然比 Pro Max 少一顆鏡頭",
      "start": "00:06:28.541",
      "end": "00:06:30.875"
    },
    {
      "text": "會讓我覺得它",
      "start": "00:06:30.875",
      "end": "00:06:32.000"
    },
    {
      "text": "不夠 Ultra",
      "start": "00:06:32.083",
      "end": "00:06:33.000"
    },
    {
      "text": "第三 MagSafe",
      "start": "00:06:33.000",
      "end": "00:06:34.291"
    },
    {
      "text": "呃這個我其實不是很確定",
      "start": "00:06:34.291",
      "end": "00:06:35.875"
    },
    {
      "text": "只是如果你看 iPhone 18 Pro Max 的機模",
      "start": "00:06:35.875",
      "end": "00:06:38.375"
    },
    {
      "text": "就會發現上面畫出了 MagSafe 的位置",
      "start": "00:06:38.375",
      "end": "00:06:41.166"
    },
    {
      "text": "畢竟這是給配件廠商做配件用的",
      "start": "00:06:41.166",
      "end": "00:06:43.833"
    },
    {
      "text": "MagSafe 的位置很重要",
      "start": "00:06:43.833",
      "end": "00:06:45.375"
    },
    {
      "text": "但是 iPhone Ultra 的機模上就沒有",
      "start": "00:06:45.375",
      "end": "00:06:47.666"
    },
    {
      "text": "我真的希望是機模的問題",
      "start": "00:06:47.666",
      "end": "00:06:49.500"
    },
    {
      "text": "而不是它因為太薄",
      "start": "00:06:49.500",
      "end": "00:06:50.958"
    },
    {
      "text": "放不下",
      "start": "00:06:50.958",
      "end": "00:06:51.750"
    },
    {
      "text": "MagSafe 的配件生態",
      "start": "00:06:51.750",
      "end": "00:06:53.000"
    },
    {
      "text": "是 iPhone 最棒的屬性之一",
      "start": "00:06:53.000",
      "end": "00:06:54.750"
    },
    {
      "text": "真的不要捨棄啊",
      "start": "00:06:54.750",
      "end": "00:06:56.750"
    },
    {
      "text": "剩下就是一些稱不上驚喜",
      "start": "00:06:56.750",
      "end": "00:06:58.333"
    },
    {
      "text": "也稱不上是妥協的細節",
      "start": "00:06:58.333",
      "end": "00:07:00.000"
    },
    {
      "text": "比如 iPhone Ultra 展開以後",
      "start": "00:07:00.000",
      "end": "00:07:01.750"
    },
    {
      "text": "厚度大概是 5.5 毫米左右",
      "start": "00:07:01.750",
      "end": "00:07:03.958"
    },
    {
      "text": "比 iPhone Air 更薄",
      "start": "00:07:03.958",
      "end": "00:07:05.166"
    },
    {
      "text": "但比很多最新的折疊屏要更厚",
      "start": "00:07:05.166",
      "end": "00:07:07.500"
    },
    {
      "text": "當然也塞下了 iPhone",
      "start": "00:07:07.500",
      "end": "00:07:08.708"
    },
    {
      "text": "歷史上最大的電池",
      "start": "00:07:08.708",
      "end": "00:07:10.291"
    },
    {
      "text": "容量在 5400 毫安培時和 5800 毫安培時之間",
      "start": "00:07:10.291",
      "end": "00:07:13.666"
    },
    {
      "text": "iPhone Ultra 理所當然也用上了",
      "start": "00:07:13.666",
      "end": "00:07:15.416"
    },
    {
      "text": "最新的 2 納米制程",
      "start": "00:07:15.416",
      "end": "00:07:16.833"
    },
    {
      "text": "封裝在一起",
      "start": "00:07:20.112",
      "end": "00:07:21.029"
    },
    {
      "text": "更進一步降低了能耗",
      "start": "00:07:21.029",
      "end": "00:07:22.820"
    },
    {
      "text": "所以這次的續航應該會是相當不錯的",
      "start": "00:07:22.820",
      "end": "00:07:25.654"
    },
    {
      "text": "展開以後",
      "start": "00:07:25.654",
      "end": "00:07:26.362"
    },
    {
      "text": "揚聲器在一個很奇怪的位置",
      "start": "00:07:26.362",
      "end": "00:07:28.445"
    },
    {
      "text": "左上角",
      "start": "00:07:28.445",
      "end": "00:07:29.320"
    },
    {
      "text": "和右下角",
      "start": "00:07:29.987",
      "end": "00:07:30.904"
    },
    {
      "text": "還有一個比較奇怪的地方",
      "start": "00:07:30.904",
      "end": "00:07:32.612"
    },
    {
      "text": "音量鍵在頂上",
      "start": "00:07:32.612",
      "end": "00:07:34.612"
    },
    {
      "text": "和 iPad mini 一樣左右排布",
      "start": "00:07:34.612",
      "end": "00:07:36.820"
    },
    {
      "text": "左邊是音量加",
      "start": "00:07:36.820",
      "end": "00:07:37.862"
    },
    {
      "text": "還是右邊是音量加",
      "start": "00:07:37.862",
      "end": "00:07:39.029"
    },
    {
      "text": "這件事情就跟",
      "start": "00:07:39.029",
      "end": "00:07:39.820"
    },
    {
      "text": "甜豆腐腦和鹹豆腐腦之爭一樣",
      "start": "00:07:39.820",
      "end": "00:07:41.987"
    },
    {
      "text": "人類是不可能達成一個共識的",
      "start": "00:07:41.987",
      "end": "00:07:44.112"
    },
    {
      "text": "這說明肯定至少有一半的人",
      "start": "00:07:44.112",
      "end": "00:07:45.862"
    },
    {
      "text": "買回來就要默默的去適應",
      "start": "00:07:45.862",
      "end": "00:07:48.029"
    },
    {
      "text": "總的來說",
      "start": "00:07:49.612",
      "end": "00:07:50.362"
    },
    {
      "text": "iPhone Ultra 確實是一個可能賣到 18000 多",
      "start": "00:07:50.362",
      "end": "00:07:54.279"
    },
    {
      "text": "可以對折放進口袋的 iPad mini",
      "start": "00:07:54.279",
      "end": "00:07:56.695"
    },
    {
      "text": "它確實會帶來一些實用性",
      "start": "00:07:56.695",
      "end": "00:07:58.320"
    },
    {
      "text": "但它肯定沒有帶來任何性價比",
      "start": "00:07:58.320",
      "end": "00:08:00.779"
    },
    {
      "text": "所以我感覺",
      "start": "00:08:00.779",
      "end": "00:08:01.487"
    },
    {
      "text": "它的外觀辨識度",
      "start": "00:08:01.487",
      "end": "00:08:02.695"
    },
    {
      "text": "才是它最大的賣點",
      "start": "00:08:02.695",
      "end": "00:08:04.029"
    },
    {
      "text": "是蘋果最新輕奢定位的產品",
      "start": "00:08:04.029",
      "end": "00:08:06.904"
    },
    {
      "text": "想要掏走 iPhone Pro Max 用戶手裏",
      "start": "00:08:06.904",
      "end": "00:08:09.320"
    },
    {
      "text": "那剩餘的預算",
      "start": "00:08:09.320",
      "end": "00:08:11.154"
    },
    {
      "text": "前面說了這麼多 iPhone Ultra 的妥協",
      "start": "00:08:11.570",
      "end": "00:08:13.570"
    },
    {
      "text": "那你可能會想",
      "start": "00:08:13.570",
      "end": "00:08:14.612"
    },
    {
      "text": "那我幹嘛不買一個",
      "start": "00:08:14.612",
      "end": "00:08:15.987"
    },
    {
      "text": "Pro Max 呢",
      "start": "00:08:15.987",
      "end": "00:08:16.862"
    },
    {
      "text": "長焦有",
      "start": "00:08:16.862",
      "end": "00:08:17.862"
    },
    {
      "text": "Face ID 有",
      "start": "00:08:17.862",
      "end": "00:08:18.820"
    },
    {
      "text": "MagSafe 有",
      "start": "00:08:18.820",
      "end": "00:08:19.779"
    },
    {
      "text": "還便宜一萬塊",
      "start": "00:08:19.779",
      "end": "00:08:21.070"
    },
    {
      "text": "確實",
      "start": "00:08:21.070",
      "end": "00:08:21.945"
    },
    {
      "text": "所以我們一起來看看",
      "start": "00:08:21.987",
      "end": "00:08:23.029"
    },
    {
      "text": "iPhone 18 Pro Max 今年到底升級了個啥",
      "start": "00:08:23.029",
      "end": "00:08:25.862"
    },
    {
      "text": "主要都是在內在",
      "start": "00:08:27.695",
      "end": "00:08:29.195"
    },
    {
      "text": "晶片和鏡頭",
      "start": "00:08:29.195",
      "end": "00:08:30.862"
    },
    {
      "text": "晶片和 Ultra 一樣",
      "start": "00:08:30.862",
      "end": "00:08:32.320"
    },
    {
      "text": "A20 Pro 將是世界上第一個臺積電",
      "start": "00:08:32.320",
      "end": "00:08:35.070"
    },
    {
      "text": "2 納米的晶片",
      "start": "00:08:35.070",
      "end": "00:08:36.112"
    },
    {
      "text": "配合著更大的電池和新基帶",
      "start": "00:08:38.571",
      "end": "00:08:40.446"
    },
    {
      "text": "iPhone 18 Pro Max 的續航肯定是",
      "start": "00:08:40.446",
      "end": "00:08:42.738"
    },
    {
      "text": "The best iPhones we've ever made",
      "start": "00:08:42.738",
      "end": "00:08:45.488"
    },
    {
      "text": "鏡頭應該是今年 Pro Max 最大的噱頭",
      "start": "00:08:45.530",
      "end": "00:08:48.030"
    },
    {
      "text": "主攝的攝像頭",
      "start": "00:08:48.030",
      "end": "00:08:49.030"
    },
    {
      "text": "將具備可調光圈",
      "start": "00:08:49.030",
      "end": "00:08:50.363"
    },
    {
      "text": "從以前的固定 F1.78",
      "start": "00:08:50.363",
      "end": "00:08:52.155"
    },
    {
      "text": "變成 F1.4 到 F2.8 可調節",
      "start": "00:08:52.196",
      "end": "00:08:54.696"
    },
    {
      "text": "安卓已經有好幾年了",
      "start": "00:08:54.696",
      "end": "00:08:56.071"
    },
    {
      "text": "而且說實話",
      "start": "00:08:56.071",
      "end": "00:08:56.946"
    },
    {
      "text": "我覺得這不是一個有特別大用的功能",
      "start": "00:08:56.946",
      "end": "00:08:59.030"
    },
    {
      "text": "可調光圈在相機上特別有用",
      "start": "00:08:59.030",
      "end": "00:09:01.613"
    },
    {
      "text": "是因為相機感測器很大",
      "start": "00:09:01.613",
      "end": "00:09:03.405"
    },
    {
      "text": "而光圈變化範圍也大",
      "start": "00:09:03.405",
      "end": "00:09:05.363"
    },
    {
      "text": "對於 iPhone 這種小傳感器的相機來說",
      "start": "00:09:05.363",
      "end": "00:09:07.821"
    },
    {
      "text": "唯一的作用",
      "start": "00:09:07.821",
      "end": "00:09:08.488"
    },
    {
      "text": "就是放慢快門",
      "start": "00:09:08.488",
      "end": "00:09:09.905"
    },
    {
      "text": "拍視頻的時候",
      "start": "00:09:09.905",
      "end": "00:09:10.655"
    },
    {
      "text": "看起來會有更自然的動態模糊",
      "start": "00:09:10.655",
      "end": "00:09:12.488"
    },
    {
      "text": "流暢一些",
      "start": "00:09:12.488",
      "end": "00:09:13.321"
    },
    {
      "text": "相比可變光圈",
      "start": "00:09:13.321",
      "end": "00:09:14.405"
    },
    {
      "text": "最大光圈升級到 F1.4",
      "start": "00:09:14.405",
      "end": "00:09:15.905"
    },
    {
      "text": "效果會更明顯",
      "start": "00:09:15.988",
      "end": "00:09:16.988"
    },
    {
      "text": "會有顯著更好的暗光表現",
      "start": "00:09:16.988",
      "end": "00:09:19.238"
    },
    {
      "text": "順便",
      "start": "00:09:19.238",
      "end": "00:09:19.821"
    },
    {
      "text": "長焦鏡頭的光圈也會變大",
      "start": "00:09:19.821",
      "end": "00:09:21.988"
    },
    {
      "text": "前攝的解析度也會增加到 2400 萬",
      "start": "00:09:21.988",
      "end": "00:09:24.613"
    },
    {
      "text": "總之 iPhone 18 Pro Max 的相機硬體",
      "start": "00:09:24.613",
      "end": "00:09:27.155"
    },
    {
      "text": "算是小碎步的進步了一些",
      "start": "00:09:27.155",
      "end": "00:09:29.363"
    },
    {
      "text": "另外",
      "start": "00:09:29.363",
      "end": "00:09:29.821"
    },
    {
      "text": "聽說這次 Pro 也會有 eSIM",
      "start": "00:09:29.821",
      "end": "00:09:31.613"
    },
    {
      "text": "只有一個實體 SIM 卡槽",
      "start": "00:09:31.613",
      "end": "00:09:33.321"
    },
    {
      "text": "看來實體 SIM 離“壽終正寢”不遠了",
      "start": "00:09:33.321",
      "end": "00:09:36.321"
    },
    {
      "text": "而 iPhone 18 Pro 系列的外觀",
      "start": "00:09:36.321",
      "end": "00:09:38.113"
    },
    {
      "text": "就只有微小的變化",
      "start": "00:09:38.113",
      "end": "00:09:40.321"
    },
    {
      "text": "只局部微微變厚了 0.05 毫米",
      "start": "00:09:40.321",
      "end": "00:09:43.196"
    },
    {
      "text": "甚至 iPhone 17 Pro Max 的外殼",
      "start": "00:09:43.196",
      "end": "00:09:44.905"
    },
    {
      "text": "都有可能直接套上",
      "start": "00:09:44.905",
      "end": "00:09:47.196"
    },
    {
      "text": "外觀唯一的變化",
      "start": "00:09:47.196",
      "end": "00:09:48.446"
    },
    {
      "text": "就是這裏",
      "start": "00:09:48.446",
      "end": "00:09:49.363"
    },
    {
      "text": "靈動島變小了",
      "start": "00:09:49.363",
      "end": "00:09:50.988"
    },
    {
      "text": "因為 Face ID 的一部分感測器",
      "start": "00:09:50.988",
      "end": "00:09:52.988"
    },
    {
      "text": "被挪到了螢幕下麵",
      "start": "00:09:52.988",
      "end": "00:09:54.321"
    },
    {
      "text": "以及新顏色",
      "start": "00:09:54.321",
      "end": "00:09:55.321"
    },
    {
      "text": "暗櫻桃紅 淺藍 深灰",
      "start": "00:09:55.321",
      "end": "00:09:57.238"
    },
    {
      "text": "和之前的銀色",
      "start": "00:09:57.238",
      "end": "00:09:58.321"
    },
    {
      "text": "以及背面的玻璃顏色會更貼近鋁合金",
      "start": "00:09:58.321",
      "end": "00:10:00.988"
    },
    {
      "text": "不會像現在這樣有這麼大的色差",
      "start": "00:10:00.988",
      "end": "00:10:02.946"
    },
    {
      "text": "不過所有這些升級和改動",
      "start": "00:10:02.946",
      "end": "00:10:04.988"
    },
    {
      "text": "都不如一個沒有變的東西",
      "start": "00:10:04.988",
      "end": "00:10:06.655"
    },
    {
      "text": "更加令人心動",
      "start": "00:10:06.655",
      "end": "00:10:08.196"
    },
    {
      "text": "那就是價格",
      "start": "00:10:08.196",
      "end": "00:10:09.488"
    },
    {
      "text": "它",
      "start": "00:10:09.488",
      "end": "00:10:09.988"
    },
    {
      "text": "竟然沒有漲價",
      "start": "00:10:09.988",
      "end": "00:10:11.530"
    },
    {
      "text": "即使存儲和記憶體不斷起飛",
      "start": "00:10:11.821",
      "end": "00:10:13.946"
    },
    {
      "text": "還用上了更昂貴的 2 納米晶片",
      "start": "00:10:13.946",
      "end": "00:10:16.155"
    },
    {
      "text": "iPhone 18 Pro 還是將維持和 17 Pro 相同的價格結構",
      "start": "00:10:16.155",
      "end": "00:10:20.571"
    },
    {
      "text": "多出來的成本",
      "start": "00:10:20.571",
      "end": "00:10:21.405"
    },
    {
      "text": "蘋果竟然自己吃下了",
      "start": "00:10:21.405",
      "end": "00:10:23.405"
    },
    {
      "text": "也可以說",
      "start": "00:10:23.405",
      "end": "00:10:24.321"
    },
    {
      "text": "它們被轉嫁到了 iPhone Ultra 的用戶頭上了",
      "start": "00:10:24.321",
      "end": "00:10:27.196"
    },
    {
      "text": "總之",
      "start": "00:10:27.196",
      "end": "00:10:27.696"
    },
    {
      "text": "iPhone 18 Pro 在這個什麼都在漲價的年代",
      "start": "00:10:27.696",
      "end": "00:10:30.655"
    },
    {
      "text": "雖然沒有什麼新花樣",
      "start": "00:10:30.655",
      "end": "00:10:31.946"
    },
    {
      "text": "但可能是最賺的選擇",
      "start": "00:10:31.946",
      "end": "00:10:33.946"
    },
    {
      "text": "如果是想買 Ultra 的話",
      "start": "00:10:33.946",
      "end": "00:10:35.238"
    },
    {
      "text": "可以多看看今年的開發者大會",
      "start": "00:10:35.238",
      "end": "00:10:37.113"
    },
    {
      "text": "肯定會暗示一些",
      "start": "00:10:37.113",
      "end": "00:10:37.946"
    },
    {
      "text": "折疊屏能用上的神奇軟體功能",
      "start": "00:10:37.946",
      "end": "00:10:40.405"
    },
    {
      "text": "而且到時候開賣也可得盯緊了",
      "start": "00:10:40.405",
      "end": "00:10:42.446"
    },
    {
      "text": "用了這麼多新工藝",
      "start": "00:10:42.446",
      "end": "00:10:43.738"
    },
    {
      "text": "產能肯定會受限",
      "start": "00:10:43.738",
      "end": "00:10:45.113"
    },
    {
      "text": "這年頭真的是",
      "start": "00:10:45.113",
      "end": "00:10:46.363"
    },
    {
      "text": "早買早享受",
      "start": "00:10:46.363",
      "end": "00:10:47.821"
    },
    {
      "text": "晚買",
      "start": "00:10:47.821",
      "end": "00:10:48.696"
    }
  ]
}
